<section class="bundle-section">
  <div class="bundle-inner">
    <div class="s-eyebrow">Complete Your Stack</div>
    <h2 class="s-title">Bundle Your<br>Favorites</h2>
    <p class="s-sub">Build the gut-brain snack habit across your whole week.</p>
    <div class="bundle-grid">
      <div class="bundle-card featured">
        <div class="bc-band bc-band-a" data-word="SAMPLER">
          <span class="bc-badge bc-badge-a">Most Popular</span>
          <div class="bc-title bc-title-a">Try All<br>Three</div>
        </div>
        <div class="bc-body">
          <p class="bc-desc">One of each flavor — the perfect way to discover your gut-brain match.</p>
          <ul class="bc-items">
            <li><span class="bc-check bc-check-t">✓</span> 4x Chocolate Brownie Bars</li>
            <li><span class="bc-check bc-check-t">✓</span> 4x Peanut Butter Bars</li>
            <li><span class="bc-check bc-check-t">✓</span> 4x BBQ Protein Puffs</li>
            <li><span class="bc-check bc-check-t">✓</span> Free Shipping Included</li>
          </ul>
          <div class="bc-price-row"><div class="bc-price">$29.99</div><div class="bc-orig">$34.99</div><div class="bc-save bc-save-t">Save $5</div></div>
          <a href="#ProductInfo-{{ section.id }}" class="bc-btn bc-btn-a">Add Bundle to Cart</a>
        </div>
      </div>
      <div class="bundle-card">
        <div class="bc-band bc-band-b" data-word="DUO">
          <span class="bc-badge bc-badge-b">Customize</span>
          <div class="bc-title bc-title-b">Build Your<br>Duo</div>
        </div>
        <div class="bc-body">
          <p class="bc-desc">Pick any two flavors in full boxes. Mix or match.</p>
          <ul class="bc-items">
            <li><span class="bc-check bc-check-o">✓</span> 12 Bars — Your First Choice</li>
            <li><span class="bc-check bc-check-o">✓</span> 12 Bars — Your Second Choice</li>
            <li><span class="bc-check bc-check-o">✓</span> 10% Bundle Discount Applied</li>
            <li><span class="bc-check bc-check-o">✓</span> Free Shipping on Orders $25+</li>
          </ul>
          <div class="bc-price-row"><div class="bc-price">$42.99</div><div class="bc-orig">$49.98</div><div class="bc-save bc-save-o">Save 14%</div></div>
          <a href="#ProductInfo-{{ section.id }}" class="bc-btn bc-btn-b">Choose Your Flavors</a>
        </div>
      </div>
      <div class="bundle-card">
        <div class="bc-band bc-band-c" data-word="STACK">
          <span class="bc-badge bc-badge-c">Best Value</span>
          <div class="bc-title bc-title-c">Stock Up<br>Pack</div>
        </div>
        <div class="bc-body">
          <p class="bc-desc">Full month supply. Subscribe for an extra 10% off every reorder.</p>
          <ul class="bc-items">
            <li><span class="bc-check bc-check-b">✓</span> 36 Bars (3 Full Boxes)</li>
            <li><span class="bc-check bc-check-b">✓</span> 20% Off vs Single Box</li>
            <li><span class="bc-check bc-check-b">✓</span> Subscribe to Save 10% More</li>
            <li><span class="bc-check bc-check-b">✓</span> Priority Shipping</li>
          </ul>
          <div class="bc-price-row"><div class="bc-price">$59.99</div><div class="bc-orig">$74.97</div><div class="bc-save bc-save-b">Save 20%</div></div>
          <a href="#ProductInfo-{{ section.id }}" class="bc-btn bc-btn-c">Add Stock-Up Pack</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "100Cal Bundles",
  "settings": [],
  "presets": [
    { "name": "Bundles" }
  ]
}
{% endschema %}
