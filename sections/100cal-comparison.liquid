
<div class="hundred-cal">
  <section class="hc-comparison">
    <div class="hc-section-header">
      <div class="hc-eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <h2 class="hc-title">{{ section.settings.heading }}</h2>
      <p class="hc-copy">{{ section.settings.copy }}</p>
    </div>
    <div class="hc-table-wrap">
      <table class="hc-compare-table">
        <thead>
          <tr>
            <th>Snack</th><th>Calories</th><th>Protein</th><th>Fiber</th><th>Added Sugar</th><th>Net Carbs</th><th>Sugar Alcohols</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr {{ block.shopify_attributes }}>
              <td>{{ block.settings.snack }}</td>
              <td class="{% if block.settings.winner %}hc-green{% endif %}">{{ block.settings.calories | escape }}</td>
              <td class="{% if block.settings.winner %}hc-green{% endif %}">{{ block.settings.protein | escape }}</td>
              <td class="{% if block.settings.winner %}hc-green{% endif %}">{{ block.settings.fiber | escape }}</td>
              <td class="{% if block.settings.bad_added_sugar %}hc-red{% elsif block.settings.winner %}hc-green{% endif %}">{{ block.settings.added_sugar | escape }}</td>
              <td class="{% if block.settings.winner %}hc-green{% endif %}">{{ block.settings.net_carbs | escape }}</td>
              <td class="{% if block.settings.bad_sugar_alcohols %}hc-red{% elsif block.settings.winner %}hc-green{% endif %}">{{ block.settings.sugar_alcohols | escape }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% if section.settings.callout != blank %}
      <div class="hc-callout">
        <div style="font-family:var(--font-head);font-size:36px;font-weight:900;">100</div>
        <div><div class="hc-callout__title">{{ section.settings.callout_title | escape }}</div>{{ section.settings.callout }}</div>
      </div>
    {% endif %}
  </section>
</div>

{% schema %}
{
  "name": "100Cal Comparison",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "We Checked the Labels So You Don't Have To" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "The Honest<br>Comparison" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Most snacks that call themselves healthy are hiding something. It's usually in the sugar alcohol column." },
    { "type": "text", "id": "callout_title", "label": "Callout title", "default": "The Weight Loss Math" },
    { "type": "textarea", "id": "callout", "label": "Callout", "default": "Swap your daily 250-calorie snack for a 100Cal Snack and save 150 calories per day." }
  ],
  "blocks": [
    { "type": "row", "name": "Comparison row", "settings": [
      { "type": "checkbox", "id": "winner", "label": "Highlight as winner", "default": false },
      { "type": "html", "id": "snack", "label": "Snack", "default": "100Cal Snack Bar" },
      { "type": "text", "id": "calories", "label": "Calories", "default": "100" },
      { "type": "text", "id": "protein", "label": "Protein", "default": "10g" },
      { "type": "text", "id": "fiber", "label": "Fiber", "default": "5g" },
      { "type": "text", "id": "added_sugar", "label": "Added sugar", "default": "0g" },
      { "type": "text", "id": "net_carbs", "label": "Net carbs", "default": "3g" },
      { "type": "text", "id": "sugar_alcohols", "label": "Sugar alcohols", "default": "0g" },
      { "type": "checkbox", "id": "bad_added_sugar", "label": "Mark added sugar red", "default": false },
      { "type": "checkbox", "id": "bad_sugar_alcohols", "label": "Mark sugar alcohols red", "default": false }
    ] }
  ],
  "presets": [
    {
      "name": "100Cal Comparison",
      "blocks": [
        { "type": "row", "settings": { "winner": true, "snack": "100Cal Snack Bar" } },
        { "type": "row", "settings": { "snack": "The Clean Keto Bar", "calories": "200", "protein": "20g", "fiber": "14g", "added_sugar": "1g", "net_carbs": "6g", "sugar_alcohols": "8g", "bad_sugar_alcohols": true } },
        { "type": "row", "settings": { "snack": "The Natural Nuts & Honey Bar", "calories": "200", "protein": "6g", "fiber": "7g", "added_sugar": "5g", "net_carbs": "13g", "sugar_alcohols": "0g", "bad_added_sugar": true } }
      ]
    }
  ]
}
{% endschema %}
