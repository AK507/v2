
<section class="hc-gb101-arch" id="archetypes" {{ section.shopify_attributes }}>
  <div class="hcar-inner">

    <div class="hcar-header fade-up">
      <div class="hcar-eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <h2 class="hcar-h">{{ section.settings.heading }}</h2>
      <p class="hcar-sub">{{ section.settings.sub | escape }}</p>
    </div>

    <div class="hcar-grid fade-up fade-up-2">
      {% for block in section.blocks %}
        {% if block.type == 'archetype' %}
          <div class="hcar-card hcar-card--{{ block.settings.type }}" {{ block.shopify_attributes }}>
            <div class="hcar-band"></div>
            <div class="hcar-card-body">
              <div class="hcar-icon">{{ block.settings.icon | escape }}</div>
              <div class="hcar-type">{{ block.settings.type_name | escape }}</div>
              <div class="hcar-tagline">{{ block.settings.tagline | escape }}</div>
              <div class="hcar-experiences">
                <div class="hcar-exp-label">Common Experiences</div>
                <ul class="hcar-exp-list">
                  {% if block.settings.exp1 != blank %}<li>{{ block.settings.exp1 | escape }}</li>{% endif %}
                  {% if block.settings.exp2 != blank %}<li>{{ block.settings.exp2 | escape }}</li>{% endif %}
                  {% if block.settings.exp3 != blank %}<li>{{ block.settings.exp3 | escape }}</li>{% endif %}
                </ul>
              </div>
              <div class="hcar-helps">
                <div class="hcar-helps-label">What Helps</div>
                <div class="hcar-helps-text">{{ block.settings.helps_text | escape }}</div>
              </div>
              <a href="{{ block.settings.product_url | escape }}" class="hcar-product">
                <div class="hcar-product-name">{{ block.settings.product_name | escape }}</div>
                <div class="hcar-product-arrow">Shop →</div>
              </a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Quiz CTA strip -->
    <div class="hcar-quiz-strip fade-up fade-up-3">
      <div>
        <div class="hcar-quiz-title">{{ section.settings.quiz_heading | escape }}</div>
        <div class="hcar-quiz-sub">{{ section.settings.quiz_sub | escape }}</div>
      </div>
      <a href="{{ section.settings.quiz_url | escape }}" class="pill-btn hcar-quiz-btn">{{ section.settings.quiz_btn_text | escape }}</a>
    </div>

    <!-- Product preview strip -->
    <div class="hcar-preview-wrap fade-up fade-up-4">
      <div class="hcar-preview-eyebrow">{{ section.settings.preview_eyebrow | escape }}</div>
      <div class="hcar-preview-grid">
        {% for block in section.blocks %}
          {% if block.type == 'product_preview' %}
            <a href="{{ block.settings.url | escape }}" class="hcar-preview-card hcar-preview-card--{{ block.settings.type }}" {{ block.shopify_attributes }}>
              <div class="hcar-preview-emoji">{{ block.settings.emoji | escape }}</div>
              <div class="hcar-preview-name">{{ block.settings.name | escape }}</div>
              <div class="hcar-preview-type">{{ block.settings.type_label | escape }}</div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
.hc-gb101-arch {
  padding: 100px 80px;
  background: #0F1415;
  border-top: 1px solid rgba(255,255,255,.06);
}
.hc-gb101-arch .hcar-inner { max-width: 1200px; margin: 0 auto; }
.hc-gb101-arch .hcar-header { margin-bottom: 56px; }
.hc-gb101-arch .hcar-eyebrow {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 16px;
}
.hc-gb101-arch .hcar-h {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 64px;
  line-height: .9;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 16px;
}
.hc-gb101-arch .hcar-sub {
  font-family: var(--font-body);
  font-size: 16px;
  color: rgba(255,255,255,.65);
  max-width: 560px;
  line-height: 1.7;
}
/* Archetype grid */
.hc-gb101-arch .hcar-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: rgba(255,255,255,.05);
}
.hc-gb101-arch .hcar-card {
  background: var(--black);
  display: flex;
  flex-direction: column;
  transition: all .3s;
  position: relative;
  overflow: hidden;
}
.hc-gb101-arch .hcar-card--focus:hover { background: #100B06; }
.hc-gb101-arch .hcar-card--calm:hover  { background: #0F0C06; }
.hc-gb101-arch .hcar-card--craving:hover { background: #100900; }
.hc-gb101-arch .hcar-band { height: 6px; }
.hc-gb101-arch .hcar-card--focus  .hcar-band { background: #C4854A; }
.hc-gb101-arch .hcar-card--calm   .hcar-band { background: #C49A3C; }
.hc-gb101-arch .hcar-card--craving .hcar-band { background: #F5A623; }
.hc-gb101-arch .hcar-card-body { padding: 36px 32px; flex: 1; display: flex; flex-direction: column; }
.hc-gb101-arch .hcar-icon { font-size: 36px; margin-bottom: 16px; }
.hc-gb101-arch .hcar-type {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 28px;
  text-transform: uppercase;
  color: var(--white);
  letter-spacing: .5px;
  line-height: 1;
  margin-bottom: 4px;
}
.hc-gb101-arch .hcar-tagline {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
  margin-bottom: 24px;
}
.hc-gb101-arch .hcar-exp-label {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: rgba(255,255,255,.45);
  margin-bottom: 10px;
}
.hc-gb101-arch .hcar-exp-list { list-style: none; display: flex; flex-direction: column; gap: 7px; margin-bottom: 24px; }
.hc-gb101-arch .hcar-exp-list li {
  font-family: var(--font-body);
  font-size: 14px;
  color: rgba(255,255,255,.68);
  display: flex;
  align-items: flex-start;
  gap: 8px;
  line-height: 1.4;
}
.hc-gb101-arch .hcar-exp-list li::before { content: '·'; flex-shrink: 0; color: rgba(255,255,255,.25); }
.hc-gb101-arch .hcar-helps { padding: 16px; margin-bottom: 20px; }
.hc-gb101-arch .hcar-card--focus  .hcar-helps { background: rgba(196,133,74,.14); border-left: 3px solid #C4854A; }
.hc-gb101-arch .hcar-card--calm   .hcar-helps { background: rgba(196,154,60,.14); border-left: 3px solid #C49A3C; }
.hc-gb101-arch .hcar-card--craving .hcar-helps { background: rgba(245,166,35,.14); border-left: 3px solid #F5A623; }
.hc-gb101-arch .hcar-helps-label {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 9px;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.hc-gb101-arch .hcar-card--focus  .hcar-helps-label { color: #C4854A; }
.hc-gb101-arch .hcar-card--calm   .hcar-helps-label { color: #C49A3C; }
.hc-gb101-arch .hcar-card--craving .hcar-helps-label { color: #F5A623; }
.hc-gb101-arch .hcar-helps-text {
  font-family: var(--font-body);
  font-size: 13px;
  color: rgba(255,255,255,.72);
  line-height: 1.5;
}
.hc-gb101-arch .hcar-product {
  margin-top: auto;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.04);
  text-decoration: none;
}
.hc-gb101-arch .hcar-product-name {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 14px;
  text-transform: uppercase;
  color: var(--white);
  letter-spacing: .5px;
}
.hc-gb101-arch .hcar-product-arrow {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 1px;
  text-transform: uppercase;
  transition: color .2s;
}
.hc-gb101-arch .hcar-card--focus  .hcar-product-arrow { color: #C4854A; }
.hc-gb101-arch .hcar-card--calm   .hcar-product-arrow { color: #C49A3C; }
.hc-gb101-arch .hcar-card--craving .hcar-product-arrow { color: #F5A623; }
/* Quiz strip */
.hc-gb101-arch .hcar-quiz-strip {
  margin-top: 40px;
  padding: 32px;
  background: rgba(102,204,204,.05);
  border: 1px solid rgba(102,204,204,.12);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}
.hc-gb101-arch .hcar-quiz-title {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 22px;
  text-transform: uppercase;
  color: var(--white);
  letter-spacing: .5px;
  margin-bottom: 4px;
}
.hc-gb101-arch .hcar-quiz-sub {
  font-family: var(--font-body);
  font-size: 14px;
  color: rgba(255,255,255,.5);
}
.hc-gb101-arch .hcar-quiz-btn { white-space: nowrap; flex-shrink: 0; }
/* Product preview */
.hc-gb101-arch .hcar-preview-wrap { margin-top: 32px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,.06); }
.hc-gb101-arch .hcar-preview-eyebrow {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
  margin-bottom: 16px;
}
.hc-gb101-arch .hcar-preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: rgba(255,255,255,.05);
}
.hc-gb101-arch .hcar-preview-card {
  background: var(--black);
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  text-decoration: none;
  border-top: 3px solid transparent;
  transition: all .25s;
}
.hc-gb101-arch .hcar-preview-card:hover { background: rgba(255,255,255,.03); }
.hc-gb101-arch .hcar-preview-card--focus   { border-top-color: #C4854A; }
.hc-gb101-arch .hcar-preview-card--calm    { border-top-color: #C49A3C; }
.hc-gb101-arch .hcar-preview-card--craving { border-top-color: #F5A623; }
.hc-gb101-arch .hcar-preview-emoji { font-size: 28px; margin-bottom: 4px; }
.hc-gb101-arch .hcar-preview-name {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 17px;
  text-transform: uppercase;
  color: var(--white);
  letter-spacing: .5px;
  line-height: 1;
}
.hc-gb101-arch .hcar-preview-type {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
}
.hc-gb101-arch .hcar-preview-card--focus   .hcar-preview-type { color: #C4854A; }
.hc-gb101-arch .hcar-preview-card--calm    .hcar-preview-type { color: #C49A3C; }
.hc-gb101-arch .hcar-preview-card--craving .hcar-preview-type { color: #F5A623; }
@media (max-width: 1024px) {
  .hc-gb101-arch { padding: 72px 40px; }
  .hc-gb101-arch .hcar-grid { grid-template-columns: 1fr; }
  .hc-gb101-arch .hcar-preview-grid { grid-template-columns: 1fr; }
  .hc-gb101-arch .hcar-h { font-size: 48px; }
}
@media (max-width: 768px) {
  .hc-gb101-arch { padding: 56px 20px; }
  .hc-gb101-arch .hcar-h { font-size: 38px; }
  .hc-gb101-arch .hcar-quiz-strip { flex-direction: column; align-items: flex-start; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "GB101 Archetypes",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The 3 Gut-Brain Patterns" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Which Gut-Brain Pattern Fits You?" },
    { "type": "textarea", "id": "sub", "label": "Subheading", "default": "Most people consistently experience one dominant gut-brain pattern. Recognizing yours is the first step to snacking with intention." },
    { "type": "text", "id": "quiz_heading", "label": "Quiz strip heading", "default": "Not Sure Which Gut-Brain Pattern Fits You?" },
    { "type": "textarea", "id": "quiz_sub", "label": "Quiz strip subtext", "default": "Take the free 60-second quiz → Discover your gut-brain score, your dominant pattern, and the snack designed for your body." },
    { "type": "text", "id": "quiz_btn_text", "label": "Quiz button text", "default": "Take the Quiz →" },
    { "type": "text", "id": "quiz_url", "label": "Quiz button URL", "default": "/pages/gut-brain-quiz" },
    { "type": "text", "id": "preview_eyebrow", "label": "Product preview eyebrow", "default": "Designed for These Patterns" }
  ],
  "blocks": [
    {
      "type": "archetype",
      "name": "Archetype card",
      "settings": [
        { "type": "select", "id": "type", "label": "Type", "default": "focus", "options": [
          { "value": "focus",   "label": "Focus Fueler" },
          { "value": "calm",    "label": "Calm Operator" },
          { "value": "craving", "label": "Craving Crusher" }
        ]},
        { "type": "text", "id": "icon",      "label": "Icon (emoji)" },
        { "type": "text", "id": "type_name", "label": "Type name" },
        { "type": "text", "id": "tagline",   "label": "Tagline" },
        { "type": "text", "id": "exp1",      "label": "Experience 1" },
        { "type": "text", "id": "exp2",      "label": "Experience 2" },
        { "type": "text", "id": "exp3",      "label": "Experience 3" },
        { "type": "textarea", "id": "helps_text",    "label": "What helps text" },
        { "type": "text", "id": "product_name", "label": "Product name" },
        { "type": "text", "id": "product_url",  "label": "Product URL" }
      ]
    },
    {
      "type": "product_preview",
      "name": "Product preview",
      "settings": [
        { "type": "select", "id": "type", "label": "Type", "default": "focus", "options": [
          { "value": "focus",   "label": "Focus Fueler" },
          { "value": "calm",    "label": "Calm Operator" },
          { "value": "craving", "label": "Craving Crusher" }
        ]},
        { "type": "text", "id": "emoji",      "label": "Emoji" },
        { "type": "text", "id": "name",       "label": "Product name" },
        { "type": "text", "id": "type_label", "label": "Type label" },
        { "type": "text", "id": "url",        "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "GB101 Archetypes" }]
}
{% endschema %}
