{% render '100cal-assets' %}
<section class="hc-gb101-axis" id="what-is-axis" {{ section.shopify_attributes }}>
  <div class="hcax-inner">

    <div class="hcax-diagram fade-up">
      <div class="hcax-node hcax-node--brain">
        <div class="hcax-node-icon">{{ section.settings.brain_icon | escape }}</div>
        <div class="hcax-node-label">{{ section.settings.brain_label | escape }}</div>
        <div class="hcax-node-sub">{{ section.settings.brain_sub | escape }}</div>
      </div>
      <div class="hcax-nerve">
        <div class="hcax-nerve-track">
          <div class="hcax-track-label">GUT-BRAIN<br>AXIS</div>
          <div class="hcax-nerve-line">
            <div class="hcax-signal hcax-d1"></div>
            <div class="hcax-signal hcax-d2"></div>
            <div class="hcax-signal hcax-u1"></div>
            <div class="hcax-signal hcax-u2"></div>
          </div>
        </div>
        <div class="hcax-channels">
          {% for block in section.blocks %}
            {% if block.type == 'axis_channel' %}
              <div class="hcax-channel hcax-ch--{{ block.settings.color }}" {{ block.shopify_attributes }}>
                <div class="hcax-ch-name">{{ block.settings.name | escape }}</div>
                <div class="hcax-ch-desc">{{ block.settings.description | escape }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="hcax-node hcax-node--gut">
        <div class="hcax-node-icon">{{ section.settings.gut_icon | escape }}</div>
        <div class="hcax-node-label">{{ section.settings.gut_label | escape }}</div>
        <div class="hcax-node-sub">{{ section.settings.gut_sub | escape }}</div>
      </div>
      <p class="hcax-caption">{{ section.settings.diagram_caption | escape }}</p>
    </div>

    <div class="hcax-copy fade-up fade-up-2">
      <div class="hcax-eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <h2 class="hcax-h">{{ section.settings.heading }}</h2>
      <p class="hcax-body">{{ section.settings.body | escape }}</p>
      <ul class="hcax-list">
        {% for block in section.blocks %}
          {% if block.type == 'axis_point' %}
            <li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
          {% endif %}
        {% endfor %}
      </ul>
      <div class="hcax-callout">{{ section.settings.callout | escape }}</div>
    </div>

  </div>
</section>

{% stylesheet %}
.hc-gb101-axis {
  --ink: #1A1A1A;
  padding: 100px 80px;
  background: #0A1A1A;
  border-top: 1px solid rgba(102,204,204,.1);
  position: relative;
}
.hc-gb101-axis .hcax-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 100px;
  align-items: center;
}
/* Diagram */
.hc-gb101-axis .hcax-diagram {
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 340px;
  margin: 0 auto;
}
.hc-gb101-axis .hcax-node {
  border: 2px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.03);
  padding: 24px 28px;
  width: 100%;
}
.hc-gb101-axis .hcax-node--brain { border-top: 3px solid var(--teal); }
.hc-gb101-axis .hcax-node--gut { border-top: 3px solid var(--orange); }
.hc-gb101-axis .hcax-node-icon { font-size: 32px; margin-bottom: 10px; }
.hc-gb101-axis .hcax-node-label {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 28px;
  text-transform: uppercase;
  color: var(--white);
  letter-spacing: .5px;
  margin-bottom: 4px;
}
.hc-gb101-axis .hcax-node-sub {
  font-family: var(--font-body);
  font-size: 13px;
  color: rgba(255,255,255,.35);
  line-height: 1.4;
}
/* Nerve connector */
.hc-gb101-axis .hcax-nerve {
  width: 100%;
  padding: 8px 0;
  display: grid;
  grid-template-columns: 56px 1fr;
  gap: 0 20px;
  align-items: start;
}
.hc-gb101-axis .hcax-nerve-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4px 0;
  gap: 0;
  height: 100%;
}
.hc-gb101-axis .hcax-track-label {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 9px;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--teal);
  text-align: center;
  margin-bottom: 8px;
  border: 1px solid rgba(102,204,204,.25);
  padding: 5px 8px;
  white-space: nowrap;
  line-height: 1.4;
}
.hc-gb101-axis .hcax-nerve-line {
  width: 2px;
  flex: 1;
  background: linear-gradient(180deg, var(--teal) 0%, rgba(233,173,60,.5) 50%, var(--orange) 100%);
  opacity: .45;
  border-radius: 2px;
  position: relative;
  min-height: 120px;
}
/* Animated signals */
@keyframes hcAxGoDown {
  0% { top: 2%; opacity: 0; transform: translateX(-50%) scale(.4); }
  12% { opacity: 1; transform: translateX(-50%) scale(1); }
  88% { opacity: 1; transform: translateX(-50%) scale(1); }
  100% { top: 95%; opacity: 0; transform: translateX(-50%) scale(.4); }
}
@keyframes hcAxGoUp {
  0% { top: 95%; opacity: 0; transform: translateX(-50%) scale(.4); }
  12% { opacity: 1; transform: translateX(-50%) scale(1); }
  88% { opacity: 1; transform: translateX(-50%) scale(1); }
  100% { top: 2%; opacity: 0; transform: translateX(-50%) scale(.4); }
}
.hc-gb101-axis .hcax-signal {
  position: absolute;
  border-radius: 50%;
  left: 50%;
  transform: translateX(-50%);
  width: 9px;
  height: 9px;
}
.hc-gb101-axis .hcax-d1,
.hc-gb101-axis .hcax-d2 {
  background: var(--teal);
  box-shadow: 0 0 7px var(--teal);
  animation: hcAxGoDown 2.2s ease-in-out infinite;
}
.hc-gb101-axis .hcax-d2 { animation-delay: 1.1s; }
.hc-gb101-axis .hcax-u1,
.hc-gb101-axis .hcax-u2 {
  background: var(--orange);
  box-shadow: 0 0 7px var(--orange);
  animation: hcAxGoUp 2.2s ease-in-out infinite;
  animation-delay: .55s;
}
.hc-gb101-axis .hcax-u2 { animation-delay: 1.65s; }
/* Channels */
.hc-gb101-axis .hcax-channels {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.hc-gb101-axis .hcax-channel {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 14px 0 14px 16px;
  border-bottom: 1px solid rgba(255,255,255,.06);
  border-left: 2px solid rgba(255,255,255,.06);
}
.hc-gb101-axis .hcax-channel:last-child { border-bottom: none; }
.hc-gb101-axis .hcax-ch--teal { border-left-color: var(--teal); }
.hc-gb101-axis .hcax-ch--yellow { border-left-color: var(--yellow); }
.hc-gb101-axis .hcax-ch--orange { border-left-color: var(--orange); }
.hc-gb101-axis .hcax-ch-name {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: .5px;
  line-height: 1;
  margin-bottom: 4px;
}
.hc-gb101-axis .hcax-ch--teal .hcax-ch-name { color: var(--teal); }
.hc-gb101-axis .hcax-ch--yellow .hcax-ch-name { color: var(--yellow); }
.hc-gb101-axis .hcax-ch--orange .hcax-ch-name { color: var(--orange); }
.hc-gb101-axis .hcax-ch-desc {
  font-family: var(--font-body);
  font-size: 12px;
  color: rgba(255,255,255,.5);
  line-height: 1.45;
}
/* Caption */
.hc-gb101-axis .hcax-caption {
  font-family: var(--font-body);
  font-size: 12px;
  color: rgba(255,255,255,.2);
  text-align: center;
  margin-top: 20px;
  line-height: 1.5;
}
/* Copy side */
.hc-gb101-axis .hcax-eyebrow {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 16px;
}
.hc-gb101-axis .hcax-h {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 60px;
  line-height: .9;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 24px;
}
.hc-gb101-axis .hcax-body {
  font-family: var(--font-body);
  font-size: 16px;
  color: rgba(255,255,255,.72);
  line-height: 1.8;
  margin-bottom: 24px;
}
.hc-gb101-axis .hcax-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 28px;
}
.hc-gb101-axis .hcax-list li {
  font-family: var(--font-body);
  font-size: 15px;
  color: rgba(255,255,255,.7);
  display: flex;
  align-items: center;
  gap: 12px;
  line-height: 1.5;
}
.hc-gb101-axis .hcax-list li::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--teal);
  flex-shrink: 0;
}
.hc-gb101-axis .hcax-callout {
  border-left: 3px solid var(--teal);
  padding: 18px 22px;
  background: rgba(102,204,204,.08);
  font-family: var(--font-body);
  font-size: 15px;
  color: rgba(255,255,255,.75);
  line-height: 1.65;
  font-style: italic;
}
@media (max-width: 1024px) {
  .hc-gb101-axis { padding: 72px 40px; }
  .hc-gb101-axis .hcax-inner { grid-template-columns: 1fr; gap: 56px; }
  .hc-gb101-axis .hcax-h { font-size: 44px; }
}
@media (max-width: 768px) {
  .hc-gb101-axis { padding: 56px 20px; }
  .hc-gb101-axis .hcax-h { font-size: 36px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "GB101 Axis",
  "settings": [
    { "type": "text", "id": "brain_icon", "label": "Brain icon", "default": "🧠" },
    { "type": "text", "id": "brain_label", "label": "Brain label", "default": "Brain" },
    { "type": "text", "id": "brain_sub", "label": "Brain subtext", "default": "Mood · Focus · Stress Response · Sleep" },
    { "type": "text", "id": "gut_icon", "label": "Gut icon", "default": "🦠" },
    { "type": "text", "id": "gut_label", "label": "Gut label", "default": "Gut" },
    { "type": "text", "id": "gut_sub", "label": "Gut subtext", "default": "Digestion · Microbiome · Immunity · Energy" },
    { "type": "text", "id": "diagram_caption", "label": "Diagram caption", "default": "Signals travel in both directions — 24 hours a day" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Science" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Your Gut and Brain<br>Are Always Talking" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "The gut brain connection is one of the most important — and most overlooked — systems in your body. Your gut and brain are linked by a powerful two-way network called the gut-brain axis: a system of nerves, hormones, and neurotransmitters that runs between your digestive system and your brain." },
    { "type": "textarea", "id": "callout", "label": "Callout quote", "default": "When the gut is inflamed or out of balance, the brain feels it — and vice versa. This is why snacking isn't just about calories. It's about communication." }
  ],
  "blocks": [
    {
      "type": "axis_point",
      "name": "Axis point",
      "settings": [
        { "type": "text", "id": "text", "label": "Point text", "default": "Mood and emotional regulation" }
      ]
    },
    {
      "type": "axis_channel",
      "name": "Axis channel",
      "settings": [
        { "type": "text", "id": "name", "label": "Channel name", "default": "Vagus Nerve" },
        { "type": "select", "id": "color", "label": "Color", "default": "teal", "options": [
          { "value": "teal", "label": "Teal" },
          { "value": "yellow", "label": "Yellow" },
          { "value": "orange", "label": "Orange" }
        ]},
        { "type": "textarea", "id": "description", "label": "Description", "default": "Real-time electrical signals between brain and gut — the body's primary two-way highway" }
      ]
    }
  ],
  "max_blocks": 15,
  "presets": [{ "name": "GB101 Axis" }]
}
{% endschema %}
