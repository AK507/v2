{% render '100cal-assets' %}
<section class="hc-gb101-hero" {{ section.shopify_attributes }}>
  <svg class="hcgh-bg" viewBox="0 0 600 700" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <ellipse cx="300" cy="160" rx="130" ry="110" stroke="white" stroke-width="3" opacity=".6"/>
