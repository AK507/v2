  </svg>
  <div class="hcgh-inner">
    <div class="hcgh-overline">{{ section.settings.eyebrow | escape }}</div>
    <h1 class="hcgh-h1">{{ section.settings.heading }}</h1>
    <p class="hcgh-sub">{{ section.settings.subheading | escape }}</p>
    <div class="hcgh-ctas">
      <a href="{{ section.settings.primary_link | default: '/pages/quiz' }}" class="hcgh-pill-btn">{{ section.settings.primary_label | escape }}</a>
      <a href="{{ section.settings.secondary_link | escape }}" class="hcgh-ghost-btn">{{ section.settings.secondary_label | escape }}</a>
