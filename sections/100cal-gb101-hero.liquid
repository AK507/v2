  </div>
  <div class="hcgh-scroll-hint">
    <div class="hcgh-scroll-line"></div>
    {{ section.settings.scroll_hint | escape }}
  </div>
</section>

{% stylesheet %}
.hc-gb101-hero {
  --ink: #1A1A1A;
  min-height: 92vh;
  background: var(--black);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 80px 80px 80px 56px;
}
.hc-gb101-hero .hcgh-bg {
  position: absolute;
  right: -80px;
  top: 50%;
  transform: translateY(-50%);
  width: 600px;
  height: 700px;
  opacity: .06;
  pointer-events: none;
}
.hc-gb101-hero .hcgh-inner {
  max-width: 720px;
  position: relative;
  z-index: 2;
}
.hc-gb101-hero .hcgh-overline {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.hc-gb101-hero .hcgh-overline::before {
  content: '';
  width: 32px;
  height: 2px;
  background: var(--teal);
  flex-shrink: 0;
}
.hc-gb101-hero .hcgh-h1 {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 108px;
  line-height: .88;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 28px;
}
.hc-gb101-hero .hcgh-h1 em {
  font-style: italic;
  color: var(--teal);
}
.hc-gb101-hero .hcgh-sub {
  font-family: var(--font-body);
  font-size: 18px;
  color: rgba(255,255,255,.5);
  line-height: 1.7;
  max-width: 520px;
  margin-bottom: 40px;
}
.hc-gb101-hero .hcgh-ctas {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
}
.hc-gb101-hero .hcgh-pill-btn {
  display: inline-block;
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 14px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 18px 44px;
  background: var(--teal);
  color: var(--black);
  text-decoration: none;
  transition: all .25s;
}
.hc-gb101-hero .hcgh-pill-btn:hover {
  background: var(--teal-dark);
  color: var(--white);
}
.hc-gb101-hero .hcgh-ghost-btn {
  display: inline-block;
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 14px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 16px 40px;
  background: transparent;
  color: var(--white);
  border: 2px solid rgba(255,255,255,.25);
  text-decoration: none;
  transition: all .25s;
}
.hc-gb101-hero .hcgh-ghost-btn:hover {
  border-color: var(--white);
  background: rgba(255,255,255,.06);
}
.hc-gb101-hero .hcgh-scroll-hint {
  position: absolute;
  bottom: 40px;
  left: 56px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,.2);
}
.hc-gb101-hero .hcgh-scroll-line {
  width: 40px;
  height: 1px;
  background: rgba(255,255,255,.15);
}
@media (max-width: 1024px) {
  .hc-gb101-hero { padding: 72px 40px; }
  .hc-gb101-hero .hcgh-h1 { font-size: 80px; }
  .hc-gb101-hero .hcgh-bg { display: none; }
}
@media (max-width: 768px) {
  .hc-gb101-hero { padding: 56px 20px; min-height: auto; padding-bottom: 72px; }
  .hc-gb101-hero .hcgh-h1 { font-size: 60px; }
  .hc-gb101-hero .hcgh-sub { font-size: 16px; }
  .hc-gb101-hero .hcgh-scroll-hint { display: none; }
}
{% endstylesheet %}

{% javascript %}
(() => {
  const boot = () => {
    if (window._hcFadeInit) return;
    window._hcFadeInit = true;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
    document.querySelectorAll('.fade-up').forEach((el) => io.observe(el));
  };
  document.addEventListener('DOMContentLoaded', boot);
  document.addEventListener('shopify:section:load', boot);
  boot();
})();
{% endjavascript %}

{% schema %}
{
  "name": "GB101 Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Gut-Brain Nutrition 101" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Your Gut Feeds<br>Your <em>Brain.</em>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Your gut and brain communicate constantly. What you snack on shapes your energy, focus, and cravings." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Take the Gut-Brain Quiz →" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Learn the Science ↓" },
    { "type": "text", "id": "secondary_link", "label": "Secondary button link", "default": "#what-is-axis" },
    { "type": "text", "id": "scroll_hint", "label": "Scroll hint text", "default": "Scroll to explore" }
  ],
  "blocks": [],
  "presets": [{ "name": "GB101 Hero" }]
}
{% endschema %}
