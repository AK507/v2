    <path d="M385 165 C390 148 378 138 366 142" stroke="white" stroke-width="2" fill="none" opacity=".4"/>
    <path d="M248 190 C258 205 280 208 295 200 C310 208 332 205 342 190" stroke="white" stroke-width="2" fill="none" opacity=".4"/>
    <path d="M300 270 C290 310 308 340 298 375 C288 410 305 435 298 465" stroke="white" stroke-width="3" stroke-dasharray="10 12" opacity=".5"/>
    <circle cx="299" cy="318" r="6" fill="white" opacity=".5"/>
    <circle cx="301" cy="362" r="6" fill="white" opacity=".4"/>
    <circle cx="299" cy="406" r="5" fill="white" opacity=".35"/>
    <path d="M180 490 C165 490 152 502 152 518 C152 534 165 546 180 546 C196 546 210 534 210 518 C210 502 222 490 238 490 C254 490 266 502 266 518 C266 534 254 546 238 546 C222 546 210 558 210 574 C210 590 222 602 238 602 C254 602 268 596 278 584" stroke="white" stroke-width="3.5" fill="none" opacity=".55"/>
    <path d="M180 490 C168 476 170 460 182 452 C202 438 228 442 242 454 C258 468 280 466 296 454 C312 442 332 444 344 456 C356 470 352 488 340 496 C326 504 316 520 322 537 C328 554 344 560 356 552 C368 544 368 528 356 520 C344 512 326 514 318 526 C310 538 314 556 328 562" stroke="white" stroke-width="3" fill="none" opacity=".45"/>
    <line x1="158" y1="526" x2="320" y2="526" stroke="white" stroke-width="2" opacity=".25"/>
