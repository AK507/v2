{% render '100cal-assets' %}

<div class="hundred-cal">
  <section class="hc-guts">
    <div class="hc-eyebrow">{{ section.settings.eyebrow | escape }}</div>
    <h2 class="hc-title" style="color:var(--white);">{{ section.settings.heading }}</h2>
    <p class="hc-guts__copy">{{ section.settings.copy }}</p>
    <div class="hc-cta-row" style="justify-content:center;">
      <a href="{{ section.settings.primary_link }}" class="hc-btn hc-btn--black">{{ section.settings.primary_label }}</a>
      <a href="{{ section.settings.secondary_link | default: '#science' }}" class="hc-btn hc-btn--outline">{{ section.settings.secondary_label }}</a>
    </div>
    <div class="hc-stat-row">
      {% for block in section.blocks %}
        <div class="hc-stat" {{ block.shopify_attributes }}>
          <div class="hc-stat__num">{{ block.settings.number | escape }}</div>
          <div class="hc-stat__label">{{ block.settings.label | escape }}</div>
        </div>
      {% endfor %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "100Cal Guts CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your Brain is in Your Belly" },
    { "type": "html", "id": "heading", "label": "Heading", "default": "Do You Have The Guts?" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Health isn't a straight line. It's messy, frustrating, and it takes guts - the kind that keeps showing up." },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Find My Snack ->" },
    { "type": "url", "id": "primary_link", "label": "Primary link", "default": "/collections/all" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Read the Science" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" }
  ],
  "blocks": [
    { "type": "stat", "name": "Stat", "settings": [
      { "type": "text", "id": "number", "label": "Number", "default": "1,200+" },
      { "type": "text", "id": "label", "label": "Label", "default": "5-Star Reviews" }
    ] }
  ],
  "presets": [
    {
      "name": "100Cal Guts CTA",
      "blocks": [
        { "type": "stat", "settings": { "number": "1,200+", "label": "5-Star Reviews" } },
        { "type": "stat", "settings": { "number": "0g", "label": "Sugar Alcohols" } },
        { "type": "stat", "settings": { "number": "100", "label": "Clean Calories" } },
        { "type": "stat", "settings": { "number": "1", "label": "Overqualified Formula" } }
      ]
    }
  ]
}
{% endschema %}
