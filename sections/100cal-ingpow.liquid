<section class="ingpow-section">
  <div class="ingpow-inner">
    <div class="ingpow-header">
      <div class="ingpow-eyebrow">{{ section.settings.ingpow_eyebrow | escape }}</div>
      <h2 class="ingpow-title">{{ section.settings.ingpow_title | newline_to_br }}</h2>
    </div>
    <div class="ingpow-grid">
      <div class="ingpow-card">
        <div class="ingpow-img ingpow-img-ashwa">
          <svg viewBox="0 0 80 80" width="72" height="72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="40" cy="58" rx="18" ry="10" fill="rgba(196,133,74,.15)" />
            <rect x="36" y="28" width="8" height="30" rx="4" fill="#C4854A" opacity=".9"/>
            <rect x="30" y="35" width="6" height="20" rx="3" fill="#A0673A" opacity=".8" transform="rotate(-15 30 35)"/>
            <rect x="44" y="33" width="6" height="22" rx="3" fill="#A0673A" opacity=".8" transform="rotate(12 44 33)"/>
            <ellipse cx="40" cy="26" rx="10" ry="14" fill="none" stroke="#7aab7a" stroke-width="1.5" opacity=".7"/>
            <ellipse cx="40" cy="22" rx="7" ry="10" fill="none" stroke="#7aab7a" stroke-width="1.2" opacity=".5"/>
            <circle cx="40" cy="14" r="4" ry="5" fill="#7aab7a" opacity=".6"/>
            <path d="M34 20 Q30 14 26 16" stroke="#7aab7a" stroke-width="1.2" fill="none" opacity=".5"/>
            <path d="M46 20 Q50 14 54 16" stroke="#7aab7a" stroke-width="1.2" fill="none" opacity=".5"/>
          </svg>
        </div>
        <div class="ingpow-benefit">{{ section.settings.card_1_benefit }}</div>
        <div class="ingpow-name">{{ section.settings.card_1_name }}</div>
        <div class="ingpow-dose">{{ section.settings.card_1_dose }}</div>
      </div>

      <div class="ingpow-card">
        <div class="ingpow-img ingpow-img-fiber">
          <svg viewBox="0 0 80 80" width="72" height="72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="40" cy="60" rx="22" ry="8" fill="rgba(102,204,204,.1)"/>
            <path d="M32 55 Q28 42 30 30 Q32 20 38 16" stroke="#C4854A" stroke-width="5" fill="none" stroke-linecap="round" opacity=".9"/>
            <path d="M44 56 Q46 44 44 32 Q42 22 38 16" stroke="#A0673A" stroke-width="4" fill="none" stroke-linecap="round" opacity=".8"/>
            <path d="M36 50 Q28 46 24 40" stroke="#A0673A" stroke-width="3" fill="none" stroke-linecap="round" opacity=".6"/>
            <path d="M40 44 Q50 40 54 34" stroke="#A0673A" stroke-width="3" fill="none" stroke-linecap="round" opacity=".6"/>
            <circle cx="38" cy="16" r="6" fill="#66CCCC" opacity=".7"/>
            <circle cx="32" cy="22" r="4" fill="#66CCCC" opacity=".5"/>
            <circle cx="44" cy="20" r="4" fill="#66CCCC" opacity=".5"/>
          </svg>
        </div>
        <div class="ingpow-benefit">{{ section.settings.card_2_benefit }}</div>
        <div class="ingpow-name">{{ section.settings.card_2_name }}</div>
        <div class="ingpow-dose">{{ section.settings.card_2_dose }}</div>
      </div>

      <div class="ingpow-card">
        <div class="ingpow-img ingpow-img-mct">
          <svg viewBox="0 0 80 80" width="72" height="72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="40" cy="62" rx="20" ry="7" fill="rgba(196,133,74,.12)"/>
            <ellipse cx="40" cy="44" rx="22" ry="20" fill="#5C3D2E" opacity=".9"/>
            <ellipse cx="40" cy="44" rx="22" ry="20" fill="none" stroke="#A0673A" stroke-width="1.5" opacity=".4"/>
            <ellipse cx="40" cy="38" rx="14" ry="12" fill="#8B5E3C" opacity=".8"/>
            <ellipse cx="40" cy="36" rx="9" ry="8" fill="#C4854A" opacity=".6"/>
            <path d="M24 35 Q28 28 32 30" stroke="#7aab7a" stroke-width="2" fill="none" opacity=".6"/>
            <path d="M56 35 Q52 28 48 30" stroke="#7aab7a" stroke-width="2" fill="none" opacity=".6"/>
            <ellipse cx="40" cy="22" rx="8" ry="5" fill="#7aab7a" opacity=".5"/>
          </svg>
        </div>
        <div class="ingpow-benefit">{{ section.settings.card_3_benefit }}</div>
        <div class="ingpow-name">{{ section.settings.card_3_name }}</div>
        <div class="ingpow-dose">{{ section.settings.card_3_dose }}</div>
      </div>

      <div class="ingpow-card">
        <div class="ingpow-img ingpow-img-cocoa">
          <svg viewBox="0 0 80 80" width="72" height="72" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="40" cy="58" rx="16" ry="8" fill="rgba(90,40,10,.2)"/>
            <ellipse cx="40" cy="40" rx="18" ry="26" fill="#5C2E0A" opacity=".9" transform="rotate(-10 40 40)"/>
            <ellipse cx="40" cy="40" rx="14" ry="22" fill="#7B3F10" opacity=".7" transform="rotate(-10 40 40)"/>
            <path d="M28 30 Q40 26 52 30" stroke="#C4854A" stroke-width="1.2" fill="none" opacity=".5"/>
            <path d="M26 38 Q40 34 54 38" stroke="#C4854A" stroke-width="1.2" fill="none" opacity=".5"/>
            <path d="M28 46 Q40 42 52 46" stroke="#C4854A" stroke-width="1.2" fill="none" opacity=".4"/>
            <rect x="38" y="12" width="4" height="10" rx="2" fill="#7aab7a" opacity=".6"/>
            <ellipse cx="40" cy="11" rx="6" ry="4" fill="#7aab7a" opacity=".5"/>
          </svg>
        </div>
        <div class="ingpow-benefit">{{ section.settings.card_4_benefit }}</div>
        <div class="ingpow-name">{{ section.settings.card_4_name }}</div>
        <div class="ingpow-dose">{{ section.settings.card_4_dose }}</div>
      </div>
    </div>

    <details class="full-ing-wrap" style="margin-top:32px">
      <summary class="full-ing-toggle">
        ▼ &nbsp;Full Ingredient List
        <span class="full-ing-chevron">▾</span>
      </summary>
      <div class="full-ing-body">
        <div class="full-ing-content">
          <p class="full-ing-list">{{ section.settings.full_ing_list }}</p>
          <p class="full-ing-allergens">{{ section.settings.allergens_text }}</p>
          <div class="dietary-callouts">
            <span class="dc-badge">{{ section.settings.badge_1 }}</span>
            <span class="dc-badge">{{ section.settings.badge_2 }}</span>
            <span class="dc-badge">{{ section.settings.badge_3 }}</span>
            <span class="dc-badge">{{ section.settings.badge_4 }}</span>
            <span class="dc-badge">{{ section.settings.badge_5 }}</span>
          </div>
        </div>
      </div>
    </details>
  </div>
</section>

{% schema %}
{
  "name": "100Cal Ingredients",
  "settings": [
    { "type": "text", "id": "ingpow_eyebrow", "label": "Eyebrow", "default": "The Ingredients Doing the Heavy Lifting" },
    { "type": "textarea", "id": "ingpow_title", "label": "Title", "default": "Built from\nReal Ingredients That Work." },
    { "type": "text", "id": "card_1_benefit", "label": "Card 1 benefit", "default": "Supports Stress Balance" },
    { "type": "text", "id": "card_1_name", "label": "Card 1 name", "default": "Ashwagandha" },
    { "type": "text", "id": "card_1_dose", "label": "Card 1 dose", "default": "250mg · Clinically Relevant" },
    { "type": "text", "id": "card_2_benefit", "label": "Card 2 benefit", "default": "Feeds Your Gut" },
    { "type": "text", "id": "card_2_name", "label": "Card 2 name", "default": "Prebiotic Fiber" },
    { "type": "text", "id": "card_2_dose", "label": "Card 2 dose", "default": "Chicory Root · Gut Microbiome" },
    { "type": "text", "id": "card_3_benefit", "label": "Card 3 benefit", "default": "Fast Brain Energy" },
    { "type": "text", "id": "card_3_name", "label": "Card 3 name", "default": "MCT Oil" },
    { "type": "text", "id": "card_3_dose", "label": "Card 3 dose", "default": "Organic · Immediate Fuel" },
    { "type": "text", "id": "card_4_benefit", "label": "Card 4 benefit", "default": "Rich in Antioxidants" },
    { "type": "text", "id": "card_4_name", "label": "Card 4 name", "default": "Cocoa Flavanols" },
    { "type": "text", "id": "card_4_dose", "label": "Card 4 dose", "default": "Organic · Brain Health" },
    { "type": "textarea", "id": "full_ing_list", "label": "Full ingredient list", "default": "Organic Almond Butter, Organic Almond Flour, Allulose, Chicory Root Fiber, Organic Unsweetened Chocolate Chips, Protein Blend (Organic Pea Protein, Organic Brown Rice Protein), Organic Cocoa Powder (Processed with Alkali), Organic Cocoa Butter, Organic Sunflower Lecithin, Natural Flavors, Organic Ashwagandha Extract, Organic MCT Oil (From Coconut), Himalayan Pink Salt, Organic Flaxseed Oil, Organic Monk Fruit Extract, Organic Rosemary Extract." },
    { "type": "textarea", "id": "allergens_text", "label": "Allergens text", "default": "<strong>Contains:</strong> Tree Nuts (Almonds).<br><strong>May contain:</strong> Peanuts, other Tree Nuts." },
    { "type": "text", "id": "badge_1", "label": "Badge 1", "default": "Gluten Free" },
    { "type": "text", "id": "badge_2", "label": "Badge 2", "default": "No Added Sugar" },
    { "type": "text", "id": "badge_3", "label": "Badge 3", "default": "No Sugar Alcohols" },
    { "type": "text", "id": "badge_4", "label": "Badge 4", "default": "Vegan" },
    { "type": "text", "id": "badge_5", "label": "Badge 5", "default": "Non-GMO" }
  ],
  "presets": [
    { "name": "Ingredients & Power" }
  ]
}
{% endschema %}
