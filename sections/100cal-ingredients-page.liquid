{% render '100cal-assets' %}

<div class="hundred-cal hc-ingredients-page" data-100cal-ingredients-page {{ section.shopify_attributes }}>
  <section class="hero">
    <div class="hero-inner">
      <div>
        <div class="eyebrow hero-overline">{{ section.settings.hero_eyebrow | escape }}</div>
        <h1 class="hero-h1">{{ section.settings.hero_heading }}</h1>
        <p class="hero-sub">{{ section.settings.hero_subheading | escape | newline_to_br }}</p>
        <div class="hero-micro">{{ section.settings.hero_micro | escape }}</div>
        <div class="hero-ctas">
          {% if section.settings.primary_link != blank %}
            <a href="{{ section.settings.primary_link }}" class="pill-btn">{{ section.settings.primary_label | escape }}</a>
          {% endif %}
          {% if section.settings.secondary_link != blank %}
            <a href="{{ section.settings.secondary_link }}" class="ghost-btn">{{ section.settings.secondary_label | escape }}</a>
          {% endif %}
        </div>
      </div>

      <div class="hero-mosaic fade-up">
        <div class="mosaic-label-top">{{ section.settings.mosaic_title | escape }}</div>
        {% for block in section.blocks %}
          {% if block.type == 'mosaic_item' %}
            <a href="{{ block.settings.anchor | default: '#' }}" class="mosaic-cell" {{ block.shopify_attributes }}>
              <div class="mosaic-icon">{{ block.settings.icon | escape }}</div>
              <div class="mosaic-text">
                <div class="mosaic-label">{{ block.settings.label | escape }}</div>
                <div class="mosaic-sublabel">{{ block.settings.subtext | escape }}</div>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="framework-section">
    <div class="framework-inner">
      <div class="framework-header fade-up">
        <div>
          <div class="eyebrow" style="margin-bottom:14px">{{ section.settings.framework_eyebrow | escape }}</div>
          <h2 class="framework-h">{{ section.settings.framework_heading }}</h2>
        </div>
        <p class="framework-sub">{{ section.settings.framework_subheading | escape | newline_to_br }}</p>
      </div>
      <div class="framework-grid fade-up fade-up-2">
        {% for block in section.blocks %}
          {% if block.type == 'framework_card' %}
            <div class="framework-block" {{ block.shopify_attributes }}>
              <div class="framework-icon">{{ block.settings.icon | escape }}</div>
              <div class="framework-name">{{ block.settings.title | escape }}</div>
              <div class="framework-desc">{{ block.settings.description | escape }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="dosing-section">
    <div class="dosing-inner">
      <div class="dosing-left fade-up">
        <div class="eyebrow" style="margin-bottom:14px">{{ section.settings.dosing_eyebrow | escape }}</div>
        <h2 class="dosing-h">{{ section.settings.dosing_heading }}</h2>
      </div>
      <div class="dosing-right fade-up fade-up-2">
        <p class="dosing-body">{{ section.settings.dosing_body | escape | newline_to_br }}</p>
        <div class="dosing-stats">
          {% for block in section.blocks %}
            {% if block.type == 'stat_card' %}
              <div class="dosing-stat" {{ block.shopify_attributes }}>
                <div class="dosing-stat-num">{{ block.settings.value | escape }}</div>
                <div class="dosing-stat-label">{{ block.settings.label | escape }}</div>
                <div class="dosing-stat-sub">{{ block.settings.subtext | escape }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        <div class="dosing-callout">{{ section.settings.dosing_callout | escape | newline_to_br }}</div>
      </div>
    </div>
  </section>

  <section class="library-section" id="library">
    <div class="library-inner">
      <div class="library-header fade-up">
        <div class="eyebrow" style="margin-bottom:14px">{{ section.settings.library_eyebrow | escape }}</div>
        <h2 class="library-h">{{ section.settings.library_heading }}</h2>
        <p class="library-sub">{{ section.settings.library_subheading | escape | newline_to_br }}</p>
      </div>

      <div class="filter-tabs fade-up fade-up-2">
        <button type="button" class="filter-tab active" data-filter-tab="all">{{ section.settings.filter_all | escape }}</button>
        <button type="button" class="filter-tab" data-filter-tab="fiber">{{ section.settings.filter_fiber | escape }}</button>
        <button type="button" class="filter-tab" data-filter-tab="protein">{{ section.settings.filter_protein | escape }}</button>
        <button type="button" class="filter-tab" data-filter-tab="fats">{{ section.settings.filter_fats | escape }}</button>
        <button type="button" class="filter-tab" data-filter-tab="adaptogens">{{ section.settings.filter_adaptogens | escape }}</button>
        <button type="button" class="filter-tab" data-filter-tab="antioxidants">{{ section.settings.filter_antioxidants | escape }}</button>
        <button type="button" class="filter-tab" data-filter-tab="sweeteners">{{ section.settings.filter_sweeteners | escape }}</button>
        <button type="button" class="filter-tab" data-filter-tab="other">{{ section.settings.filter_other | escape }}</button>
      </div>

      {% assign groups = 'fiber|protein|fats|adaptogens|antioxidants|sweeteners|other' | split: '|' %}
      {% for group in groups %}
        <div class="ingr-group fade-up" data-group="{{ group }}" {% if group == 'fiber' %}id="chicory"{% elsif group == 'protein' %}id="protein"{% elsif group == 'fats' %}id="almond-butter"{% elsif group == 'adaptogens' %}id="ashwagandha"{% elsif group == 'antioxidants' %}id="cocoa"{% elsif group == 'sweeteners' %}id="monk-fruit"{% endif %}>
          {% case group %}
            {% when 'fiber' %}
              <div class="group-header" style="border-left-color:var(--teal)">
                <div class="group-icon">{{ section.settings.group_fiber_icon | escape }}</div>
                <div class="group-name">{{ section.settings.group_fiber_name | escape }}</div>
                <div class="group-count">{{ section.settings.group_fiber_count | escape }}</div>
              </div>
            {% when 'protein' %}
              <div class="group-header" style="border-left-color:var(--orange)">
                <div class="group-icon">{{ section.settings.group_protein_icon | escape }}</div>
                <div class="group-name">{{ section.settings.group_protein_name | escape }}</div>
                <div class="group-count">{{ section.settings.group_protein_count | escape }}</div>
              </div>
            {% when 'fats' %}
              <div class="group-header" style="border-left-color:var(--yellow)">
                <div class="group-icon">{{ section.settings.group_fats_icon | escape }}</div>
                <div class="group-name">{{ section.settings.group_fats_name | escape }}</div>
                <div class="group-count">{{ section.settings.group_fats_count | escape }}</div>
              </div>
            {% when 'adaptogens' %}
              <div class="group-header" style="border-left-color:var(--teal-pastel)">
                <div class="group-icon">{{ section.settings.group_adaptogens_icon | escape }}</div>
                <div class="group-name">{{ section.settings.group_adaptogens_name | escape }}</div>
                <div class="group-count">{{ section.settings.group_adaptogens_count | escape }}</div>
              </div>
            {% when 'antioxidants' %}
              <div class="group-header" style="border-left-color:var(--grey-dark)">
                <div class="group-icon">{{ section.settings.group_antioxidants_icon | escape }}</div>
                <div class="group-name">{{ section.settings.group_antioxidants_name | escape }}</div>
                <div class="group-count">{{ section.settings.group_antioxidants_count | escape }}</div>
              </div>
            {% when 'sweeteners' %}
              <div class="group-header" style="border-left-color:var(--grey-warm)">
                <div class="group-icon">{{ section.settings.group_sweeteners_icon | escape }}</div>
                <div class="group-name">{{ section.settings.group_sweeteners_name | escape }}</div>
                <div class="group-count">{{ section.settings.group_sweeteners_count | escape }}</div>
              </div>
            {% else %}
              <div class="group-header">
                <div class="group-icon">{{ section.settings.group_other_icon | escape }}</div>
                <div class="group-name">{{ section.settings.group_other_name | escape }}</div>
                <div class="group-count">{{ section.settings.group_other_count | escape }}</div>
              </div>
          {% endcase %}

          <div class="ingr-cards">
            {% for block in section.blocks %}
              {% if block.type == 'ingredient_card' and block.settings.group == group %}
                <div class="ingr-card" {{ block.shopify_attributes }}>
                  <button type="button" class="ingr-card-toggle">+</button>
                  <div class="ingr-card-header">
                    <div class="ingr-card-icon">{{ block.settings.icon | escape }}</div>
                    <div class="ingr-card-top">
                      <div class="ingr-card-name">{{ block.settings.name | escape }}</div>
                      <div class="ingr-card-tagline">{{ block.settings.tagline | escape }}</div>
                    </div>
                  </div>
                  <div class="ingr-card-body">
                    <div class="ingr-card-detail">
                      <div class="ingr-detail-row">
                        <div class="ingr-detail-label">What it is</div>
                        <div class="ingr-detail-text">{{ block.settings.what_it_is | escape }}</div>
                      </div>
                      <div class="ingr-detail-row">
                        <div class="ingr-detail-label">Why it matters</div>
                        <div class="ingr-detail-text">{{ block.settings.why_it_matters | escape }}</div>
                      </div>
                      <div class="ingr-detail-row">
                        <div class="ingr-detail-label">Gut-Brain Benefit</div>
                        <div class="ingr-detail-text gut-brain">{{ block.settings.gut_brain_benefit | escape }}</div>
                      </div>
                      <div class="ingr-detail-row">
                        <div class="ingr-detail-label">Appears In</div>
                        <div class="ingr-products">
                          {% if block.settings.product_1 != blank %}<span class="ingr-product-tag choc">{{ block.settings.product_1 | escape }}</span>{% endif %}
                          {% if block.settings.product_2 != blank %}<span class="ingr-product-tag pb">{{ block.settings.product_2 | escape }}</span>{% endif %}
                          {% if block.settings.product_3 != blank %}<span class="ingr-product-tag bbq">{{ block.settings.product_3 | escape }}</span>{% endif %}
                        </div>
                      </div>
                      {% if block.settings.read_more_label != blank and block.settings.read_more_link != blank %}
                        <div class="ingr-detail-row">
                          <div class="ingr-read-more-label">{{ block.settings.read_more_label | escape }}</div>
                          <a href="{{ block.settings.read_more_link }}" class="ingr-read-more" target="{% if block.settings.open_new_tab %}_blank{% else %}_self{% endif %}">{{ block.settings.read_more_text | escape }}</a>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </section>

  <section class="sweet-section">
    <div class="sweet-inner">
      <div class="fade-up">
        <div class="eyebrow" style="margin-bottom:14px">{{ section.settings.sweet_eyebrow | escape }}</div>
        <h2 class="sweet-h">{{ section.settings.sweet_heading }}</h2>
        <p class="sweet-body">{{ section.settings.sweet_body_1 | escape | newline_to_br }}</p>
        <p class="sweet-body">{{ section.settings.sweet_body_2 | escape | newline_to_br }}</p>
      </div>
      <div class="fade-up fade-up-2">
        <div class="sweet-vs">
          <div class="sweet-col no">
            <div class="sweet-col-label">{{ section.settings.sweet_avoid_title | escape }}</div>
            {% for block in section.blocks %}
              {% if block.type == 'sweetener_avoid_item' %}
                <div class="sweet-item"><span class="si-mark">✗</span>{{ block.settings.label | escape }}</div>
              {% endif %}
            {% endfor %}
          </div>
          <div class="sweet-col yes">
            <div class="sweet-col-label">{{ section.settings.sweet_use_title | escape }}</div>
            {% for block in section.blocks %}
              {% if block.type == 'sweetener_use_item' %}
                <div class="sweet-item"><span class="si-mark">✓</span>{{ block.settings.label | escape }}</div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="action-section">
    <div class="action-inner">
      <div class="action-header fade-up">
        <div class="eyebrow" style="margin-bottom:14px">{{ section.settings.action_eyebrow | escape }}</div>
        <h2 class="action-h">{{ section.settings.action_heading }}</h2>
        <p class="action-sub">{{ section.settings.action_subheading | escape }}</p>
      </div>
      <div class="action-grid fade-up fade-up-2">
        {% for block in section.blocks %}
          {% if block.type == 'action_card' %}
            <a href="{{ block.settings.link }}" class="action-card {{ block.settings.handle }}" {{ block.shopify_attributes }}>
              <div class="action-card-top">
                <div class="action-emoji">{{ block.settings.icon | escape }}</div>
                <div>
                  <div class="action-pattern">{{ block.settings.pattern | escape }}</div>
                  <div class="action-name">{{ block.settings.name | escape }}</div>
                </div>
              </div>
              <div class="action-ingredients">{{ block.settings.ingredients | escape | newline_to_br }}</div>
              <div class="action-cta">{{ block.settings.cta | escape }} <span>→</span></div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="quiz-strip">
    <div class="quiz-strip-inner">
      <div class="quiz-strip-eyebrow">{{ section.settings.quiz_eyebrow | escape }}</div>
      <h2 class="quiz-strip-h">{{ section.settings.quiz_heading }}</h2>
      <p class="quiz-strip-sub">{{ section.settings.quiz_subheading | escape | newline_to_br }}</p>
      {% if section.settings.quiz_link != blank %}
        <a href="{{ section.settings.quiz_link }}" class="quiz-strip-btn">{{ section.settings.quiz_label | escape }}</a>
      {% endif %}
    </div>
  </section>

  <section class="blog-section">
    <div class="blog-inner">
      <div class="fade-up">
        <div class="eyebrow" style="margin-bottom:14px">{{ section.settings.blog_eyebrow | escape }}</div>
        <h2 class="blog-h">{{ section.settings.blog_heading }}</h2>
      </div>
      <div class="blog-links fade-up fade-up-2">
        {% for block in section.blocks %}
          {% if block.type == 'blog_link' %}
            <a href="{{ block.settings.link }}" class="blog-link" target="{% if block.settings.open_new_tab %}_blank{% else %}_self{% endif %}" {{ block.shopify_attributes }}>
              <span class="blog-link-text">{{ block.settings.label | escape }}</span>
              <span class="blog-link-arrow">→</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
</div>

{% stylesheet %}
  .hc-ingredients-page {
    background: var(--black);
    color: var(--white);
    overflow-x: hidden;
  }

  .hc-ingredients-page a {
    color: inherit;
  }

  .hc-ingredients-page .hero,
  .hc-ingredients-page .framework-section,
  .hc-ingredients-page .dosing-section,
  .hc-ingredients-page .library-section,
  .hc-ingredients-page .sweet-section,
  .hc-ingredients-page .action-section,
  .hc-ingredients-page .blog-section,
  .hc-ingredients-page .quiz-strip {
    border-top: none;
  }

  .hc-ingredients-page .hero,
  .hc-ingredients-page .framework-section,
  .hc-ingredients-page .dosing-section,
  .hc-ingredients-page .library-section,
  .hc-ingredients-page .sweet-section,
  .hc-ingredients-page .action-section,
  .hc-ingredients-page .blog-section,
  .hc-ingredients-page .quiz-strip {
    padding-left: 80px;
    padding-right: 80px;
  }

  .hc-ingredients-page .hero,
  .hc-ingredients-page .framework-section,
  .hc-ingredients-page .dosing-section,
  .hc-ingredients-page .library-section,
  .hc-ingredients-page .sweet-section,
  .hc-ingredients-page .action-section,
  .hc-ingredients-page .blog-section,
  .hc-ingredients-page .quiz-strip,
  .hc-ingredients-page footer {
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .hc-ingredients-page .hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 80px 80px 80px 56px;
  }

  .hc-ingredients-page .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 70% 50%, rgba(102, 204, 204, .04) 0%, transparent 70%);
    pointer-events: none;
  }

  .hc-ingredients-page .hero-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hc-ingredients-page .hero-overline {
    margin-bottom: 20px;
  }

  .hc-ingredients-page .hero-h1 {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 80px;
    line-height: .88;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 28px;
  }

  .hc-ingredients-page .hero-h1 em {
    font-style: italic;
    color: var(--teal);
    display: block;
  }

  .hc-ingredients-page .hero-sub {
    font-family: var(--font-body);
    font-size: 17px;
    color: rgba(255,255,255,.55);
    line-height: 1.75;
    margin-bottom: 32px;
    max-width: 460px;
  }

  .hc-ingredients-page .hero-micro {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,.25);
    margin-bottom: 36px;
  }

  .hc-ingredients-page .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hc-ingredients-page .hero-mosaic {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .hc-ingredients-page .mosaic-label-top {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,.25);
    margin-bottom: 10px;
  }

  .hc-ingredients-page .mosaic-cell {
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.06);
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    transition: all .3s;
    text-decoration: none;
    border-left: 3px solid transparent;
  }

  .hc-ingredients-page .mosaic-cell:nth-child(2) { border-left-color: var(--teal); }
  .hc-ingredients-page .mosaic-cell:nth-child(3) { border-left-color: var(--orange); }
  .hc-ingredients-page .mosaic-cell:nth-child(4) { border-left-color: var(--yellow); }
  .hc-ingredients-page .mosaic-cell:nth-child(5) { border-left-color: var(--teal-pastel); }
  .hc-ingredients-page .mosaic-cell:nth-child(6) { border-left-color: var(--grey-dark); }
  .hc-ingredients-page .mosaic-cell:nth-child(7) { border-left-color: var(--grey-warm); }

  .hc-ingredients-page .mosaic-cell:hover {
    background: rgba(255,255,255,.05);
    border-color: rgba(255,255,255,.12);
  }

  .hc-ingredients-page .mosaic-icon {
    font-size: 22px;
    flex-shrink: 0;
    width: 32px;
    text-align: center;
  }

  .hc-ingredients-page .mosaic-label {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 15px;
    text-transform: uppercase;
    color: var(--white);
    letter-spacing: .5px;
    line-height: 1;
    margin-bottom: 2px;
  }

  .hc-ingredients-page .mosaic-sublabel {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255,255,255,.35);
    line-height: 1.3;
  }

  .hc-ingredients-page .framework-section { background: #EAE9E5; }
  .hc-ingredients-page .framework-inner { max-width: 1200px; margin: 0 auto; }
  .hc-ingredients-page .framework-header { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: end; margin-bottom: 48px; }
  .hc-ingredients-page .framework-h { font-family: var(--font-head); font-weight: 900; font-size: 52px; line-height: .9; text-transform: uppercase; color: var(--black); }
  .hc-ingredients-page .framework-sub { font-family: var(--font-body); font-size: 15px; color: rgba(15,18,19,.6); line-height: 1.7; }
  .hc-ingredients-page .framework-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
  .hc-ingredients-page .framework-block { background: #FFFFFF; padding: 32px 24px; border-top: 3px solid transparent; box-shadow: 0 1px 3px rgba(15,18,19,.06); }
  .hc-ingredients-page .framework-block:nth-child(1) { border-top-color: var(--teal); }
  .hc-ingredients-page .framework-block:nth-child(2) { border-top-color: var(--orange); }
  .hc-ingredients-page .framework-block:nth-child(3) { border-top-color: var(--yellow); }
  .hc-ingredients-page .framework-block:nth-child(4) { border-top-color: var(--grey-dark); }
  .hc-ingredients-page .framework-icon { font-size: 32px; margin-bottom: 14px; }
  .hc-ingredients-page .framework-name { font-family: var(--font-head); font-weight: 900; font-size: 20px; text-transform: uppercase; color: var(--black); letter-spacing: .5px; margin-bottom: 8px; }
  .hc-ingredients-page .framework-desc { font-family: var(--font-body); font-size: 14px; color: rgba(15,18,19,.55); line-height: 1.6; }

  .hc-ingredients-page .dosing-section { background: #C2EBEB; }
  .hc-ingredients-page .dosing-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 2fr; gap: 80px; align-items: start; }
  .hc-ingredients-page .dosing-h { font-family: var(--font-head); font-weight: 900; font-size: 64px; line-height: .88; text-transform: uppercase; color: var(--black); }
  .hc-ingredients-page .dosing-h em { font-style: italic; color: #3A9999; display: block; }
  .hc-ingredients-page .dosing-body { font-family: var(--font-body); font-size: 16px; color: rgba(15,18,19,.65); line-height: 1.75; margin-bottom: 20px; }
  .hc-ingredients-page .dosing-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin: 32px 0; }
  .hc-ingredients-page .dosing-stat { background: #0F1213; padding: 24px 20px; }
  .hc-ingredients-page .dosing-stat-num { font-family: var(--font-head); font-weight: 900; font-size: 44px; color: var(--teal); line-height: 1; margin-bottom: 6px; }
  .hc-ingredients-page .dosing-stat-label { font-family: var(--font-head); font-weight: 700; font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--white); margin-bottom: 8px; }
  .hc-ingredients-page .dosing-stat-sub { font-family: var(--font-body); font-size: 13px; color: rgba(255,255,255,.5); line-height: 1.5; }
  .hc-ingredients-page .dosing-callout { border-left: 3px solid #3A9999; padding: 18px 22px; background: rgba(15,18,19,.05); font-family: var(--font-body); font-size: 15px; color: rgba(15,18,19,.65); line-height: 1.7; font-style: italic; }

  .hc-ingredients-page .library-section { background: #111617; border-top: 1px solid rgba(255,255,255,.06); }
