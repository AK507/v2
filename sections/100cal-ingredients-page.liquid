{% javascript %}
  (() => {
    const initialize = (root) => {
      if (!root || root.dataset.ingredientsInitialized === 'true') return;
      root.dataset.ingredientsInitialized = 'true';

      const filterTabs = Array.from(root.querySelectorAll('[data-filter-tab]'));
      const groups = Array.from(root.querySelectorAll('[data-group]'));

      const setFilter = (group) => {
        filterTabs.forEach((tab) => tab.classList.toggle('active', tab.dataset.filterTab === group));
        groups.forEach((item) => {
          item.style.display = group === 'all' || item.dataset.group === group ? '' : 'none';
        });
      };

      root.addEventListener('click', (event) => {
        const tab = event.target.closest('[data-filter-tab]');
        if (tab && root.contains(tab)) {
          setFilter(tab.dataset.filterTab);
          return;
        }

        const cardToggle = event.target.closest('.ingr-card-toggle');
        if (cardToggle && root.contains(cardToggle)) {
          const card = cardToggle.closest('.ingr-card');
          if (!card) return;
          const cards = card.closest('.ingr-cards').querySelectorAll('.ingr-card');
          const wasOpen = card.classList.contains('expanded');
          cards.forEach((item) => item.classList.remove('expanded'));
          if (!wasOpen) card.classList.add('expanded');
          return;
        }

        const card = event.target.closest('.ingr-card');
        if (card && root.contains(card) && !event.target.closest('.ingr-card-toggle')) {
          const cards = card.closest('.ingr-cards').querySelectorAll('.ingr-card');
          const wasOpen = card.classList.contains('expanded');
          cards.forEach((item) => item.classList.remove('expanded'));
          if (!wasOpen) card.classList.add('expanded');
        }
      });

      const fadeEls = Array.from(root.querySelectorAll('.fade-up'));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('visible');
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

      fadeEls.forEach((el) => observer.observe(el));
      setFilter('all');
    };

    const boot = () => {
      document.querySelectorAll('[data-100cal-ingredients-page]').forEach((root) => initialize(root));
    };

    document.addEventListener('DOMContentLoaded', boot);
    document.addEventListener('shopify:section:load', boot);
    boot();
  })();
{% endjavascript %}

