
<div class="hc-policy-footer-strip" {{ section.shopify_attributes }}>
  <div class="hcpfs-inner">
    <div>
      <div class="hcpfs-eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <div class="hcpfs-links">
        {% for block in section.blocks %}
          {% if block.type == 'policy_link' %}
            <a href="{{ block.settings.url | escape }}" class="hcpfs-link" {{ block.shopify_attributes }}>{{ block.settings.label | escape }}</a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <a href="{{ section.settings.back_url | escape }}" class="hcpfs-back">{{ section.settings.back_text | escape }}</a>
  </div>
</div>

{% stylesheet %}
.hc-policy-footer-strip {
  background: var(--platinum);
  padding: 32px 80px;
  border-top: 1px solid rgba(15,18,19,.08);
}
.hc-policy-footer-strip .hcpfs-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}
.hc-policy-footer-strip .hcpfs-eyebrow {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--ink-light);
  margin-bottom: 10px;
}
.hc-policy-footer-strip .hcpfs-links {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
}
.hc-policy-footer-strip .hcpfs-link {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--ink-mid);
  text-decoration: none;
  transition: color .2s;
}
.hc-policy-footer-strip .hcpfs-link:hover { color: var(--teal-dark); }
.hc-policy-footer-strip .hcpfs-back {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 10px 22px;
  background: var(--black);
  color: var(--white);
  text-decoration: none;
  transition: background .2s;
  white-space: nowrap;
  flex-shrink: 0;
}
.hc-policy-footer-strip .hcpfs-back:hover { background: var(--teal); color: var(--black); }
@media (max-width: 768px) {
  .hc-policy-footer-strip { padding: 28px 24px; }
  .hc-policy-footer-strip .hcpfs-inner { flex-direction: column; align-items: flex-start; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Policy Footer Strip",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Other Policies" },
    { "type": "text", "id": "back_text", "label": "Back button text", "default": "← Back to Shop" },
    { "type": "text", "id": "back_url", "label": "Back button URL", "default": "/collections/all" }
  ],
  "blocks": [
    {
      "type": "policy_link",
      "name": "Policy link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "text", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [{ "name": "Policy Footer Strip" }]
}
{% endschema %}
