    { "type": "text", "id": "entry_cta", "label": "Start button text", "default": "Find My Gut-Brain Type →" },
    { "type": "text", "id": "entry_types_label", "label": "Archetype row label", "default": "3 Possible Gut-Brain Types — Which one are you?" },
    { "type": "html", "id": "email_heading", "label": "Email heading (HTML)", "default": "Get Your<br>Gut-Brain Guide" },
    { "type": "text", "id": "email_body", "label": "Email body", "default": "Enter your email and we'll send you:" },
    { "type": "text", "id": "email_bullet_1", "label": "Email bullet 1", "default": "Your personalised gut-brain profile" },
    { "type": "text", "id": "email_bullet_2", "label": "Email bullet 2", "default": "Snack timing tips for your type" },
    { "type": "text", "id": "email_bullet_3", "label": "Email bullet 3", "default": "Functional ingredient insights" },
    { "type": "text", "id": "email_bullet_4", "label": "Email bullet 4", "default": "10% off your first order" },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "your@email.com" },
    { "type": "text", "id": "email_cta", "label": "Email submit label", "default": "Send It →" },
    { "type": "text", "id": "email_privacy", "label": "Email privacy note", "default": "No spam, ever. Unsubscribe anytime." },
