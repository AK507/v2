        { "type": "text", "id": "accent_color", "label": "Accent color (hex)" },
        { "type": "text", "id": "accent_rgb", "label": "Accent RGB (r,g,b)" },
        { "type": "text", "id": "page_bg", "label": "Page background (hex)" },
        { "type": "text", "id": "hero_bg", "label": "Hero background (CSS gradient)" },
        { "type": "text", "id": "bg_word", "label": "Watermark word" },
        { "type": "text", "id": "product_name", "label": "Product name" },
        { "type": "text", "id": "product_sub", "label": "Product subtitle" },
