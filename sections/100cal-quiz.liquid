<section class="quiz-section">
  <div class="quiz-inner">
    <div class="quiz-left">
      <div class="quiz-eyebrow">Not Sure Where to Start?</div>
      <h2 class="quiz-title">Take the<br>Gut-Brain Quiz</h2>
      <p class="quiz-body">60 seconds. Discover your Gut-Brain type — and the snack that works best for you.</p>
      <a href="#reviews" class="quiz-btn">Take the Quiz →</a>
    </div>
    <div class="quiz-right">
      <div class="quiz-card">
        <div class="quiz-card-step">🧠</div>
        <div class="quiz-card-label">How's your focus?</div>
      </div>
      <div class="quiz-card">
        <div class="quiz-card-step">🌿</div>
        <div class="quiz-card-label">How's your stress?</div>
      </div>
      <div class="quiz-card">
        <div class="quiz-card-step">⚡</div>
        <div class="quiz-card-label">How's your energy?</div>
      </div>
      <div class="quiz-card quiz-card-result">
        <div class="quiz-card-step">✓</div>
        <div class="quiz-card-label">Get your match</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "100Cal Quiz",
  "settings": [],
  "presets": [
    { "name": "Quiz" }
  ]
}
{% endschema %}
