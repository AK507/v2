{% render '100cal-assets' %}
<section class="hc-reviews-feed" {{ section.shopify_attributes }}>
  <div class="rf-inner">
    <div class="rf-header fade-up">
      <h2 class="rf-h">{{ section.settings.heading | escape }}</h2>
      <div class="rf-source">{{ section.settings.source_label | escape }}</div>
    </div>
    <div class="rf-placeholder fade-up fade-up-2">
      <div class="rfp-icon">{{ section.settings.placeholder_icon | escape }}</div>
      <div class="rfp-h">{{ section.settings.placeholder_heading | escape }}</div>
      <p class="rfp-body">{{ section.settings.placeholder_body | escape }}</p>
      {% if section.settings.platforms != blank %}
        <div class="rfp-platforms">
          {% assign platforms = section.settings.platforms | newline_to_br | split: '<br />' %}
          {% for platform in platforms %}
            {% assign name = platform | strip %}
            {% if name != blank %}
              <span class="rfp-platform">{{ name | escape }}</span>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
      <div class="rf-skeleton">
        <div class="skel-card">
          <div class="skel-line stars"></div>
          <div class="skel-line" style="width:85%"></div>
          <div class="skel-line" style="width:100%"></div>
          <div class="skel-line short"></div>
        </div>
        <div class="skel-card">
          <div class="skel-line stars"></div>
          <div class="skel-line" style="width:70%"></div>
          <div class="skel-line" style="width:100%"></div>
          <div class="skel-line short"></div>
        </div>
        <div class="skel-card">
          <div class="skel-line stars"></div>
          <div class="skel-line" style="width:90%"></div>
          <div class="skel-line" style="width:100%"></div>
          <div class="skel-line short"></div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.hc-reviews-feed {
  --ink-mid: #555;
  --neutral: #F4F3F0;
  background: #EAE9E5;
  padding: 72px 80px;
}
.hc-reviews-feed .rf-inner { max-width: 1200px; margin: 0 auto; }
.hc-reviews-feed .rf-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 32px;
}
.hc-reviews-feed .rf-h {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 52px;
  line-height: .9;
  text-transform: uppercase;
  color: var(--black);
}
.hc-reviews-feed .rf-source {
  font-family: var(--font-body);
  font-size: 14px;
  color: #888;
}
.hc-reviews-feed .rf-placeholder {
  border: 2px dashed rgba(15,18,19,.15);
  padding: 64px;
  text-align: center;
  background: var(--white);
}
.hc-reviews-feed .rfp-icon { font-size: 48px; margin-bottom: 16px; opacity: .4; }
.hc-reviews-feed .rfp-h {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 28px;
  text-transform: uppercase;
  color: var(--black);
  margin-bottom: 8px;
}
.hc-reviews-feed .rfp-body {
  font-family: var(--font-body);
  font-size: 15px;
  color: #555;
  line-height: 1.65;
  max-width: 520px;
  margin: 0 auto 20px;
}
.hc-reviews-feed .rfp-platforms {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 0;
}
.hc-reviews-feed .rfp-platform {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 8px 18px;
  border: 1.5px solid rgba(15,18,19,.15);
  color: #555;
}
.hc-reviews-feed .rf-skeleton {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: rgba(15,18,19,.06);
  margin-top: 24px;
}
.hc-reviews-feed .skel-card { background: var(--white); padding: 24px 20px; }
.hc-reviews-feed .skel-line {
  height: 10px;
  background: #EAE9E5;
  border-radius: 2px;
  margin-bottom: 8px;
  animation: skel-shimmer 1.8s ease infinite;
}
.hc-reviews-feed .skel-line.short { width: 60%; }
.hc-reviews-feed .skel-line.stars { width: 80px; background: rgba(233,173,60,.2); }
@keyframes skel-shimmer { 0%,100%{opacity:.5} 50%{opacity:1} }
@media (max-width: 1024px) {
  .hc-reviews-feed { padding: 60px 40px; }
  .hc-reviews-feed .rf-header { flex-direction: column; align-items: flex-start; gap: 12px; }
  .hc-reviews-feed .rf-h { font-size: 40px; }
  .hc-reviews-feed .rf-skeleton { grid-template-columns: 1fr; }
}
@media (max-width: 768px) {
  .hc-reviews-feed { padding: 50px 20px; }
  .hc-reviews-feed .rf-placeholder { padding: 40px 24px; }
  .hc-reviews-feed .rf-h { font-size: 34px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Reviews Live Feed",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "All Reviews" },
    { "type": "text", "id": "source_label", "label": "Source label", "default": "Powered by Amazon Verified Purchases · Integration coming soon" },
    { "type": "text", "id": "placeholder_icon", "label": "Placeholder icon", "default": "⭐" },
    { "type": "text", "id": "placeholder_heading", "label": "Placeholder heading", "default": "Live Review Feed" },
    { "type": "textarea", "id": "placeholder_body", "label": "Placeholder body", "default": "This section will pull verified reviews dynamically once a review platform integration is connected. We recommend Okendo or Yotpo for Shopify — both sync Amazon reviews and allow full design control." },
    { "type": "textarea", "id": "platforms", "label": "Platform names (one per line)", "default": "Okendo\nYotpo\nJunip\nStamped.io\nAmazon API" }
  ],
  "presets": [{ "name": "Reviews Live Feed" }]
}
{% endschema %}
