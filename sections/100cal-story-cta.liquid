{% render '100cal-assets' %}
<section class="hc-story-cta" {{ section.shopify_attributes }}>
  <div class="sc-inner">
    <div class="sc-eyebrow">{{ section.settings.eyebrow | escape }}</div>
    <h2 class="sc-h">{{ section.settings.heading }}</h2>
    <p class="sc-sub">{{ section.settings.subheading | escape }}</p>
    <div class="sc-btns">
      {% if section.settings.primary_link != blank %}
        <a href="{{ section.settings.primary_link }}" class="sc-btn-dark">{{ section.settings.primary_label | escape }}</a>
      {% endif %}
      {% if section.settings.secondary_link != blank %}
        <a href="{{ section.settings.secondary_link }}" class="sc-btn-ghost">{{ section.settings.secondary_label | escape }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
.hc-story-cta {
  background: var(--teal);
  padding: 100px 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hc-story-cta::before {
  content: '100CAL';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 280px;
  color: rgba(0,0,0,.07);
  pointer-events: none;
  white-space: nowrap;
  line-height: 1;
}
.hc-story-cta .sc-inner {
  max-width: 640px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}
.hc-story-cta .sc-eyebrow {
  font-family: var(--font-head);
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(0,0,0,.45);
  margin-bottom: 20px;
}
.hc-story-cta .sc-h {
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 72px;
  line-height: .88;
  text-transform: uppercase;
  color: var(--black);
  margin-bottom: 20px;
}
.hc-story-cta .sc-h em { font-style: italic; }
.hc-story-cta .sc-sub {
  font-family: var(--font-body);
  font-size: 20px;
  color: rgba(0,0,0,.7);
  line-height: 1.7;
  margin-bottom: 40px;
  font-style: italic;
}
.hc-story-cta .sc-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.hc-story-cta .sc-btn-dark {
  display: inline-block;
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 14px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 18px 44px;
  background: var(--black);
  color: var(--white);
  text-decoration: none;
  transition: background .25s;
}
.hc-story-cta .sc-btn-dark:hover { background: #1a1a1a; }
.hc-story-cta .sc-btn-ghost {
  display: inline-block;
  font-family: var(--font-head);
  font-weight: 900;
  font-size: 14px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 16px 40px;
  background: transparent;
  color: var(--black);
  border: 2px solid rgba(0,0,0,.25);
  text-decoration: none;
  transition: all .25s;
}
.hc-story-cta .sc-btn-ghost:hover { border-color: var(--black); background: rgba(0,0,0,.06); }
@media (max-width: 1024px) { .hc-story-cta { padding: 80px 40px; } .hc-story-cta .sc-h { font-size: 56px; } }
@media (max-width: 768px) { .hc-story-cta { padding: 60px 20px; } .hc-story-cta .sc-h { font-size: 44px; } .hc-story-cta .sc-sub { font-size: 17px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Story Bottom CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ready to Try?" },
    { "type": "html", "id": "heading", "label": "Heading (HTML)", "default": "Taste What<br>This Was<br>Built For." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Thoughtfully made for steadier energy, real satisfaction, and snacks that feel as good as they taste." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop the Collection →" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Take the Quiz" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" }
  ],
  "presets": [{ "name": "Story Bottom CTA" }]
}
{% endschema %}
