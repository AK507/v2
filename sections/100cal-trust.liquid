<section class="trust-section">
  <div class="trust-inner">
    <div class="trust-cell">
      <span class="trust-cell-icon">
        <svg viewBox="0 0 32 32" width="36" height="36" xmlns="http://www.w3.org/2000/svg">
          <rect x="4" y="14" width="24" height="14" rx="2" fill="none" stroke="var(--teal)" stroke-width="1.8"/>
          <path d="M8 14V10a8 8 0 0 1 16 0v4" fill="none" stroke="var(--teal)" stroke-width="1.8" stroke-linecap="round"/>
          <circle cx="16" cy="21" r="2.5" fill="var(--teal)" opacity=".7"/>
        </svg>
      </span>
      <div class="trust-cell-title">Ships in 2–4 Days</div>
      <div class="trust-cell-sub">Free on orders $25+. Subscribe for priority fulfillment and earliest access to new drops.</div>
    </div>
    <div class="trust-cell">
      <span class="trust-cell-icon">
        <svg viewBox="0 0 32 32" width="36" height="36" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="12" fill="none" stroke="var(--teal)" stroke-width="1.8"/>
          <path d="M10 16l4 4 8-8" stroke="var(--teal)" stroke-width="2" fill="none" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="trust-cell-title">No Artificial Ingredients</div>
      <div class="trust-cell-sub">Zero artificial colors, flavors, sweeteners, or preservatives. Every ingredient earns its place.</div>
    </div>
    <div class="trust-cell">
      <span class="trust-cell-icon">
        <svg viewBox="0 0 32 32" width="36" height="36" xmlns="http://www.w3.org/2000/svg">
