          <path d="M9 12 Q6 14 6 18 Q6 25 16 28 Q26 25 26 18 Q26 14 23 12 L16 10 Z" fill="none" stroke="var(--teal)" stroke-width="1.8" stroke-linejoin="round"/>
          <path d="M12 19 l2.5 2.5 5-5" stroke="var(--teal)" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <div class="trust-cell-title">Scientist Formulated</div>
      <div class="trust-cell-sub">Every ingredient chosen for clinical relevance. Functional nutrition backed by research, not trends.</div>
    </div>
    <div class="trust-cell">
      <span class="trust-cell-icon">
        <svg viewBox="0 0 32 32" width="36" height="36" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="10" r="5.5" fill="none" stroke="var(--teal)" stroke-width="1.8"/>
          <line x1="16" y1="15.5" x2="16" y2="26" stroke="var(--teal)" stroke-width="1.8" stroke-linecap="round"/>
          <line x1="11" y1="21" x2="21" y2="21" stroke="var(--teal)" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="trust-cell-title">Woman-Owned Brand</div>
      <div class="trust-cell-sub">Built by a founder who lived the problem. Created to solve what the snack industry ignored.</div>
    </div>
