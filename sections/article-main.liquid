<div class="article-bg">
  <div class="article-layout">

    <article class="article-content">
      <div class="art-body">
        {{ article.content }}
      </div>

      {%- if section.settings.show_cta -%}
        <div class="art-cta-block">
          {%- if section.settings.cta_eyebrow != blank -%}
            <div class="acb-eyebrow">{{ section.settings.cta_eyebrow }}</div>
          {%- endif -%}
          <div class="acb-h">{{ section.settings.cta_heading }}</div>
          {%- if section.settings.cta_body != blank -%}
            <p class="acb-sub">{{ section.settings.cta_body }}</p>
          {%- endif -%}
          <div class="acb-btns">
            {%- if section.settings.cta_btn1_url != blank -%}
              <a href="{{ section.settings.cta_btn1_url }}" class="acb-btn-dark">{{ section.settings.cta_btn1_text }}</a>
            {%- endif -%}
            {%- if section.settings.cta_btn2_url != blank -%}
              <a href="{{ section.settings.cta_btn2_url }}" class="acb-btn-ghost">{{ section.settings.cta_btn2_text }}</a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <div class="art-footer-block">
        <p class="art-disclaimer">{{ section.settings.disclaimer }}</p>
      </div>

      {%- if section.settings.show_author -%}
        <div class="art-author">
          <div class="art-author-avatar">
      {%- if section.settings.author_image != blank -%}
        <img src="{{ section.settings.author_image | image_url: width: 80 }}" alt="{{ section.settings.author_name | default: article.author | escape }}" width="80" height="80" loading="lazy">
      {%- else -%}
        👤
      {%- endif -%}
    </div>
          <div>
            <div class="art-author-name">{{ section.settings.author_name | default: article.author }}</div>
            {%- if section.settings.author_title != blank -%}
              <div class="art-author-title">{{ section.settings.author_title }}</div>
            {%- endif -%}
            {%- if section.settings.author_bio != blank -%}
              <p class="art-author-bio">{{ section.settings.author_bio }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </article>

    <aside class="art-sidebar">
      {%- for block in section.blocks -%}
        {%- if block.type == 'sidebar_product' -%}
          {%- assign blk_product = block.settings.product -%}
          {%- if blk_product != blank or block.settings.product_name != blank -%}
            <div class="sb-product" {{ block.shopify_attributes }}>
              <div class="sb-product-top">
                <span class="sb-product-emoji">{{ block.settings.emoji | default: '🍫' }}</span>
                {%- if block.settings.badge != blank -%}
                  <div class="sb-product-badge">{{ block.settings.badge }}</div>
                {%- endif -%}
                <div class="sb-product-name">
                  {%- if blk_product != blank -%}{{ blk_product.title }}{%- else -%}{{ block.settings.product_name }}{%- endif -%}
                </div>
                {%- if block.settings.product_sub != blank -%}
                  <div class="sb-product-sub">{{ block.settings.product_sub }}</div>
                {%- endif -%}
              </div>
              <div class="sb-product-body">
                <div class="sb-macros">
                  {%- for i in (1..3) -%}
                    {%- assign num_key = 'macro_' | append: i | append: '_n' -%}
                    {%- assign lbl_key = 'macro_' | append: i | append: '_l' -%}
                    {%- if block.settings[num_key] != blank -%}
                      <div class="sb-macro">
                        <div class="sb-macro-num">{{ block.settings[num_key] }}</div>
                        <div class="sb-macro-lbl">{{ block.settings[lbl_key] }}</div>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- if block.settings.button_type == 'atc' and blk_product != blank and blk_product.available -%}
                  {% form 'product', blk_product %}
                    <input type="hidden" name="id" value="{{ blk_product.selected_or_first_available_variant.id }}">
                    <button class="sb-cta" type="submit">{{ block.settings.cta_text | default: 'Add to Cart' }}</button>
                  {% endform %}
                {%- else -%}
                  <a href="{{ block.settings.product_url | default: blk_product.url | default: '/collections/all' }}" class="sb-cta">{{ block.settings.cta_text | default: 'Shop Now →' }}</a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- elsif block.type == 'sidebar_card' -%}
          {%- assign card_style = block.settings.style | default: 'platinum' -%}
          <div class="sb-brand-card {{ card_style }}" {{ block.shopify_attributes }}>
            {%- if block.settings.eyebrow != blank -%}
              <div class="sbc-eyebrow">{{ block.settings.eyebrow }}</div>
            {%- endif -%}
            <div class="sbc-h">{{ block.settings.heading }}</div>
            {%- if block.settings.body != blank -%}
              <p class="sbc-body">{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.link_url != blank -%}
              <a href="{{ block.settings.link_url }}" class="sbc-link">{{ block.settings.link_text }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </aside>

  </div>
</div>

<script src="{{ 'article.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Article Main",
  "settings": [
    { "type": "header", "content": "CTA Block" },
    { "type": "checkbox", "id": "show_cta", "label": "Show CTA block", "default": true },
    { "type": "text", "id": "cta_eyebrow", "label": "Eyebrow", "default": "Find Your Gut-Brain Pattern" },
    { "type": "text", "id": "cta_heading", "label": "Heading", "default": "Which One Are You?" },
    { "type": "textarea", "id": "cta_body", "label": "Body", "default": "Focus Fueler, Calm Operator, or Craving Crusher — take the 2-minute quiz and get matched to the snack designed for your gut-brain pattern." },
    { "type": "text", "id": "cta_btn1_text", "label": "Button 1 text", "default": "Take the Quiz →" },
    { "type": "url", "id": "cta_btn1_url", "label": "Button 1 URL" },
    { "type": "text", "id": "cta_btn2_text", "label": "Button 2 text", "default": "Gut-Brain 101" },
    { "type": "url", "id": "cta_btn2_url", "label": "Button 2 URL" },
    { "type": "header", "content": "Disclaimer" },
    { "type": "textarea", "id": "disclaimer", "label": "Disclaimer text", "default": "* These statements have not been evaluated by the Food and Drug Administration. This content is for educational purposes only and is not intended to diagnose, treat, cure, or prevent any disease. Always consult a qualified healthcare professional before making changes to your diet or supplement routine." },
    { "type": "header", "content": "Author Box" },
    { "type": "checkbox", "id": "show_author", "label": "Show author box", "default": true },
    { "type": "image_picker", "id": "author_image", "label": "Author photo" },
    { "type": "text", "id": "author_name", "label": "Author name (falls back to article.author if blank)" },
    { "type": "text", "id": "author_title", "label": "Author title / credentials", "default": "Founder & CEO · 100CalSnacks · Goldman Sachs 100 Most Intriguing Entrepreneur" },
    { "type": "textarea", "id": "author_bio", "label": "Author bio", "default": "100CalSnacks was built from Tapasya's personal journey through gut health, stress, and five surgeries — and a belief that snacks should work with your biology, not against it. Every article in Snack School is grounded in the same functional ingredient science that informs our formulas." }
  ],
  "blocks": [
    {
      "type": "sidebar_product",
      "name": "Product Card",
      "settings": [
        { "type": "product", "id": "product", "label": "Shopify product" },
        { "type": "select", "id": "button_type", "label": "Button action", "options": [
          { "value": "link", "label": "Link (go to product page)" },
          { "value": "atc", "label": "Add to Cart" }
        ], "default": "link" },
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "🍫" },
        { "type": "text", "id": "badge", "label": "Badge text", "default": "Focus Fueler" },
        { "type": "text", "id": "product_name", "label": "Product name (fallback when no product selected)", "default": "Chocolate Brownie Bar" },
        { "type": "text", "id": "product_sub", "label": "Product subtitle", "default": "Ashwagandha · Prebiotic Fiber · 0g Added Sugar" },
        { "type": "url", "id": "product_url", "label": "Product URL (fallback when no product selected)" },
        { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop Now →" },
        { "type": "text", "id": "macro_1_n", "label": "Macro 1 number", "default": "100" },
        { "type": "text", "id": "macro_1_l", "label": "Macro 1 label", "default": "Cal" },
        { "type": "text", "id": "macro_2_n", "label": "Macro 2 number", "default": "5g" },
        { "type": "text", "id": "macro_2_l", "label": "Macro 2 label", "default": "Protein" },
        { "type": "text", "id": "macro_3_n", "label": "Macro 3 number", "default": "4g" },
        { "type": "text", "id": "macro_3_l", "label": "Macro 3 label", "default": "Fiber" }
      ]
    },
    {
      "type": "sidebar_card",
      "name": "Sidebar Card",
      "settings": [
        { "type": "select", "id": "style", "label": "Card style", "options": [
          { "value": "platinum", "label": "Light (platinum)" },
          { "value": "gray", "label": "Gray (neutral)" },
          { "value": "dark", "label": "Dark" }
        ], "default": "platinum" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Go Deeper" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "The Full Gut-Brain Science" },
        { "type": "textarea", "id": "body", "label": "Body text", "default": "Our Gut-Brain 101 page covers the full axis — microbiome, vagus nerve, hormones, and what it means for how you snack." },
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Read More →" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Article Main",
      "category": "Article",
      "blocks": [
        {
          "type": "sidebar_product",
          "settings": {
            "emoji": "🍫",
            "badge": "Focus Fueler",
            "product_name": "Chocolate Brownie Bar",
            "product_sub": "Ashwagandha · Prebiotic Fiber · 0g Added Sugar",
            "cta_text": "Shop Now →",
            "macro_1_n": "100",
            "macro_1_l": "Cal",
            "macro_2_n": "5g",
            "macro_2_l": "Protein",
            "macro_3_n": "4g",
            "macro_3_l": "Fiber"
          }
        },
        {
          "type": "sidebar_card",
          "settings": {
            "style": "platinum",
            "eyebrow": "Go Deeper",
            "heading": "The Full Gut-Brain Science",
            "body": "Our Gut-Brain 101 page covers the full axis — microbiome, vagus nerve, hormones, and what it means for how you snack.",
            "link_text": "Read Gut-Brain 101 →"
          }
        },
        {
          "type": "sidebar_card",
          "settings": {
            "style": "dark",
            "eyebrow": "Every Ingredient, Explained",
            "heading": "The Ingredient Index",
            "body": "Chicory root, ashwagandha, amla — see every ingredient we use and exactly why it's there.",
            "link_text": "Explore Ingredients →"
          }
        }
      ]
    }
  ]
}
{% endschema %}
