<section class="cluster-section" data-section-type="blog-cluster">
  <div class="cluster-inner">
    <div class="cluster-header">
      <div class="cluster-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="cluster-h">{{ section.settings.heading }}</h2>
    </div>
    <div class="cluster-tags">
      {% for tag in section.settings.tags | split: ',' %}
        <a href="{{ blog.url }}?tag={{ tag | strip | url_encode }}" class="cluster-tag">{{ tag | strip }}</a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Topic Cluster",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Topics We Cover" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Search What You're Curious About" },
    { "type": "text", "id": "tags", "label": "Tags (comma separated)", "default": "Gut-Brain Axis, Stress Cravings, Prebiotic Fiber, Ashwagandha, Microbiome Health" }
  ],
  "presets": [ { "name": "Topic Cluster", "category": "Blog" } ]
}
{% endschema %}
