<section class="hero" data-section-type="blog-hero">
  <div class="hero-inner">
    <div class="hero-top">
      <div>
        <div class="hero-overline">{{ section.settings.overline | default: blog.title }}</div>
        <h1 class="hero-h1">{{ section.settings.heading | default: blog.title }}</h1>
      </div>
      <div class="hero-right">
        <p class="hero-desc">{{ section.settings.description | default: blog.description }}</p>
        <div class="hero-pillars">
          {% for i in (1..4) %}
            {% assign key = 'pillar_' | append: i %}
            {% if section.settings[key] != blank %}
              <span class="hero-pillar">{{ section.settings[key] }}</span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Hero",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline (optional)", "default": "The 100Cal Blog" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Snack School." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Science-backed reads on the gut-brain axis, stress cravings, functional ingredients, and what it actually means to snack with intention." },
    { "type": "text", "id": "pillar_1", "label": "Pillar 1", "default": "Gut-Brain Health" },
    { "type": "text", "id": "pillar_2", "label": "Pillar 2", "default": "Smart Snacking" },
    { "type": "text", "id": "pillar_3", "label": "Pillar 3", "default": "Energy, Mood & Cravings" },
    { "type": "text", "id": "pillar_4", "label": "Pillar 4", "default": "Ingredients That Matter" }
  ],
  "presets": [ { "name": "Blog Hero", "category": "Blog" } ]
}
{% endschema %}
