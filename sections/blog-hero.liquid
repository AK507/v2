<section class="hero" data-section-type="blog-hero">
  <div class="hero-inner">
    <div class="hero-top">
      <div>
        <div class="hero-overline">{{ section.settings.overline | default: blog.title }}</div>
        <h1 class="hero-h1">{{ section.settings.heading | default: blog.title }}</h1>
      </div>
      <div class="hero-right">
        <p class="hero-desc">{{ section.settings.description | default: blog.description }}</p>
        <div class="hero-pillars">
          {% for i in (1..4) %}
            {% assign key = 'pillar_' | append: i %}
            {% if section.settings[key] != blank %}
              <span class="hero-pillar">{{ section.settings[key] }}</span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="featured-row fade-up fade-up-2">
      <a href="{{ section.settings.featured_link | default: '#' }}" class="featured-main" data-slug="{{ section.settings.featured_title | default: 'placeholder-featured' | handleize }}" style="--accent: {{ section.settings.accent_color }};">
        {% if section.settings.featured_image %}
        <div class="featured-main-image">
            <img src="{{ section.settings.featured_image | image_url: width: 800 }}" width="{{ section.settings.featured_image.width }}" height="{{ section.settings.featured_image.height }}" alt="{{ section.settings.featured_image.alt | escape | default: section.settings.featured_title | escape }}">          
        </div>
        {% endif %}
        <div class="featured-main-copy">
          <div class="featured-tag">★ Featured — {{ section.settings.featured_tag }}</div>
          <h2 class="featured-h">{{ section.settings.featured_title }}</h2>
          <p class="featured-excerpt">{{ section.settings.featured_excerpt }}</p>
          <div class="featured-meta">
            {% assign featured_meta_parts = section.settings.featured_meta | split: '·' %}
            {% for part in featured_meta_parts %}
              <span>{{ part | strip }}</span>{% unless forloop.last %}<span>·</span>{% endunless %}
            {% endfor %}
          </div>
          <div class="featured-read">{{ section.settings.read_more_text }}</div>
        </div>
      </a>

      <div class="featured-secondary">
        {% for block in section.blocks %}
          {% capture block_link %}{{ block.settings.link | default: '#' }}{% endcapture %}
          {% capture block_accent %}{{ block.settings.accent_color | default: '#E66443' }}{% endcapture %}
          {% capture block_tag %}{{ block.settings.tag | default: 'Smart Snacking' }}{% endcapture %}
          {% capture block_title %}{{ block.settings.title | default: 'What to Eat When Stress Makes You Crave Sugar' }}{% endcapture %}
          {% capture block_meta %}{{ block.settings.meta | default: '6 min read · Feb 2026' }}{% endcapture %}
          {% if block_link != blank %}
            <a href="{{ block_link }}" class="sec-article" style="--accent: {{ block_accent }};" {{ block.shopify_attributes }}>
          {% else %}
            <div class="sec-article" style="--accent: {{ block_accent }};" {{ block.shopify_attributes }}>
          {% endif %}
              <div class="sec-tag">{{ block_tag }}</div>
              <h3 class="sec-h">{{ block_title }}</h3>
              <div class="sec-meta">{{ block_meta }}</div>
          {% if block_link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Blog Hero",
  "settings": [
    { "type": "text", "id": "overline", "label": "Overline (optional)", "default": "The 100Cal Blog" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Snack School." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Science-backed reads on the gut-brain axis, stress cravings, functional ingredients, and what it actually means to snack with intention." },
    { "type": "text", "id": "pillar_1", "label": "Pillar 1", "default": "Gut-Brain Health" },
    { "type": "text", "id": "pillar_2", "label": "Pillar 2", "default": "Smart Snacking" },
    { "type": "text", "id": "pillar_3", "label": "Pillar 3", "default": "Energy, Mood & Cravings" },
    { "type": "text", "id": "pillar_4", "label": "Pillar 4", "default": "Ingredients That Matter" },
    { "type": "image_picker", "id": "featured_image", "label": "Featured image" },
    { "type": "text", "id": "featured_tag", "label": "Featured tag", "default": "Gut-Brain Health" },
    { "type": "text", "id": "featured_title", "label": "Featured title", "default": "Why Your Gut Controls Your Cravings — Not Your Willpower" },
    { "type": "textarea", "id": "featured_excerpt", "label": "Featured excerpt", "default": "The urge to reach for something sweet at 3pm isn't a failure of discipline. It's a signal from your gut-brain axis — and once you understand it, you can work with it instead of against it." },
    { "type": "text", "id": "featured_meta", "label": "Featured meta", "default": "8 min read · March 2026" },
    { "type": "text", "id": "read_more_text", "label": "Read more text", "default": "Read Article →" },
    { "type": "url", "id": "featured_link", "label": "Featured link" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#66CCCC" }
  ],
  "blocks": [
    {
      "type": "secondary_article",
      "name": "Secondary article",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag", "default": "Smart Snacking" },
        { "type": "text", "id": "title", "label": "Title", "default": "What to Eat When Stress Makes You Crave Sugar" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "6 min read · Feb 2026" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#E66443" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Blog Hero",
      "category": "Blog",
      "blocks": [
        {
          "type": "secondary_article",
          "settings": {
            "tag": "Smart Snacking",
            "title": "What to Eat When Stress Makes You Crave Sugar",
            "meta": "6 min read · Feb 2026",
            "accent_color": "#E66443"
          }
        },
        {
          "type": "secondary_article",
          "settings": {
            "tag": "Energy, Mood & Cravings",
            "title": "Why the 3pm Energy Crash Is a Gut Issue, Not a Sleep Issue",
            "meta": "5 min read · Feb 2026",
            "accent_color": "#E9AD3C"
          }
        },
        {
          "type": "secondary_article",
          "settings": {
            "tag": "Ingredients That Matter",
            "title": "What Prebiotic Fiber Actually Does to Your Microbiome",
            "meta": "7 min read · Jan 2026",
            "accent_color": "#A69685"
          }
        }
      ]
    }
  ]
}
{% endschema %}
